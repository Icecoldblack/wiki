---
// Why this page doesn't use the shared Layout.astro:
//
// Layout.astro is built for content pages (guides, etc.) — it injects a Navbar,
// Footer, and a cosmic star background. The course explorer is a full-page React
// app that already has its own navbar and sets its own black background via CSS.
// Keeping Layout here would cause two navbars to stack and the two backgrounds
// to conflict, so we use a plain HTML shell instead and let the React component
// own the entire page.
import CourseExplorer from "./_course-explorer";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="GSU CS course explorer — every course, every path forward." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Courses | ProGSU</title>
  </head>
  <body>
    <!-- client:load tells Astro to hydrate this React component immediately on page load -->
    <CourseExplorer client:load />
  </body>
</html>

<style>
  /* strip browser default margin so the React shell sits flush to the edges */
  body {
    margin: 0;
    padding: 0;
  }
</style>
