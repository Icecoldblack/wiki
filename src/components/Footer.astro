---
import { SITE_TITLE } from "../consts";
import SocialRow from "./SocialRow.astro";
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <SocialRow />
    <div class="site-footer__content">
      <p class="site-footer__text">
        &copy; {new Date().getFullYear()} {SITE_TITLE} &middot; built by progsu
      </p>
      <span class="site-footer__sep" aria-hidden="true">&middot;</span>
      <a href="https://github.com/progsu-official" class="site-footer__link" rel="noopener noreferrer">
        open on github
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: var(--z-base);
    border-top: 1px solid var(--accent-border);
    padding: var(--space-10) var(--page-gutter);
    margin-top: auto;
  }

  .site-footer__inner {
    max-width: var(--page-width-wide);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .site-footer__content {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .site-footer__sep {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .site-footer__text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    margin: 0;
    text-align: center;
  }

  .site-footer__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-normal) var(--ease);
  }
  .site-footer__link:hover {
    color: var(--color-text-tertiary);
  }

  @media (max-width: 480px) {
    .site-footer__content {
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
    }
    .site-footer__sep {
      display: none;
    }
  }
</style>
