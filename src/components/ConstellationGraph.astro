---
// D3 force-directed constellation graph — 3D depth edition
---

<div id="constellation-root">
  <!-- Parallax star layers — each shifts at different speed on mouse move -->
  <div class="layer-nebula" id="layer-nebula"></div>
  <div class="layer-stars layer-stars--far"  id="stars-far"></div>
  <div class="layer-stars layer-stars--mid"  id="stars-mid"></div>
  <div class="layer-stars layer-stars--near" id="stars-near"></div>
  <div class="vignette"></div>

  <!-- D3 graph -->
  <svg id="graph-svg"></svg>

  <!-- Tooltip card -->
  <div id="node-tooltip" class="tooltip" aria-hidden="true">
    <span class="tooltip__name"></span>
    <span class="tooltip__desc"></span>
    <span class="tooltip__count"></span>
  </div>
</div>

<style>
  #constellation-root {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background: #06060f;
  }

  .layer-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 45%, rgba(76,29,149,.35), transparent 70%),
      radial-gradient(ellipse 50% 40% at 20% 75%, rgba(30,27,75,.5),   transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(13,42,90,.4),   transparent 65%),
      linear-gradient(180deg, #02020a 0%, #050516 50%, #02020a 100%);
    will-change: transform;
  }

  .layer-stars { position: absolute; inset: 0; will-change: transform; }

  .layer-stars--far {
    background-image:
      radial-gradient(1px 1px at 12% 23%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 78% 67%, rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 34% 81%, rgba(255,255,255,.45), transparent),
      radial-gradient(1px 1px at 88% 14%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 5%  55%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 65% 30%, rgba(255,255,255,.3), transparent),
      radial-gradient(1px 1px at 25% 8%,  rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 95% 88%, rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 45% 18%, rgba(255,255,255,.3), transparent),
      radial-gradient(1px 1px at 15% 75%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 55% 92%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 38% 45%, rgba(255,255,255,.25), transparent);
    background-size: 280px 280px;
    animation: driftFar 180s linear infinite;
    opacity: .7;
  }

  .layer-stars--mid {
    background-image:
      radial-gradient(1.5px 1.5px at 22% 33%, rgba(255,255,255,.7), transparent),
      radial-gradient(1.5px 1.5px at 68% 57%, rgba(216,180,254,.6), transparent),
      radial-gradient(1.5px 1.5px at 84% 31%, rgba(255,255,255,.65), transparent),
      radial-gradient(1.5px 1.5px at 8%  65%, rgba(255,255,255,.6), transparent),
      radial-gradient(1.5px 1.5px at 92% 78%, rgba(186,230,253,.55), transparent),
      radial-gradient(1.5px 1.5px at 48% 88%, rgba(255,255,255,.5), transparent),
      radial-gradient(1.5px 1.5px at 33% 12%, rgba(255,255,255,.55), transparent),
      radial-gradient(1.5px 1.5px at 72% 8%,  rgba(216,180,254,.5), transparent);
    background-size: 380px 380px;
    animation: driftMid 120s linear infinite;
    opacity: .85;
  }

  .layer-stars--near {
    background-image:
      radial-gradient(2px 2px at 18% 73%, rgba(255,255,255,.95) 0%, rgba(255,255,255,.4) 30%, transparent 60%),
      radial-gradient(2px 2px at 73% 22%, rgba(216,180,254,.85) 0%, rgba(216,180,254,.3) 30%, transparent 60%),
      radial-gradient(2px 2px at 87% 84%, rgba(255,255,255,.9) 0%, rgba(255,255,255,.35) 30%, transparent 60%),
      radial-gradient(2px 2px at 6%  26%, rgba(186,230,253,.8) 0%, rgba(186,230,253,.3) 30%, transparent 60%);
    background-size: 480px 480px;
    animation: driftNear 80s linear infinite;
    opacity: .9;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 95% 80% at 50% 50%, transparent 40%, rgba(0,0,0,.65) 95%);
    pointer-events: none;
    z-index: 2;
  }

  #graph-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    cursor: grab;
    will-change: transform;
  }
  #graph-svg:active { cursor: grabbing; }

  /* Tooltip card */
  .tooltip {
    position: fixed;
    padding: .65rem .9rem;
    background: rgba(6, 6, 18, .88);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(168, 85, 247, .4);
    border-radius: .5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity .15s;
    z-index: 50;
    white-space: nowrap;
    box-shadow: 0 0 24px rgba(168, 85, 247, .2), 0 8px 32px rgba(0,0,0,.6);
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }
  .tooltip.visible { opacity: 1; }
  .tooltip__name {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: .8rem;
    color: #fff;
  }
  .tooltip__desc {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .58rem;
    color: rgba(216,180,254,.7);
    white-space: normal;
    max-width: 200px;
    line-height: 1.5;
  }
  .tooltip__count {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .52rem;
    color: rgba(255,255,255,.3);
    letter-spacing: .12em;
    margin-top: .1rem;
  }

  @keyframes driftFar  { from { transform: translate(0,0) }   to { transform: translate(60px,40px) } }
  @keyframes driftMid  { from { transform: translate(0,0) }   to { transform: translate(-80px,50px) } }
  @keyframes driftNear { from { transform: translate(0,0) }   to { transform: translate(100px,-60px) } }
</style>

<script>
  import * as d3 from "d3";

  // ── data ──────────────────────────────────────────────────────
  const NODE_DEFS = [
    { id: "wiki",        label: "progsu / wiki", desc: "",                                         central: true,  guides: 0  },
    { id: "foundations", label: "foundations",   desc: "CS theory, math, and first principles",    guides: 8,  route: "/guides/foundations" },
    { id: "career",      label: "career",         desc: "Recruiting, resumes, and offer strategy", guides: 12, route: "/guides/career" },
    { id: "networking",  label: "networking",     desc: "Cold outreach, LinkedIn, and warm intros", guides: 6, route: "/guides/networking", accent: true },
    { id: "technical",   label: "technical",      desc: "LC, system design, and take-homes",        guides: 9, route: "/guides/technical" },
    { id: "experience",  label: "experience",     desc: "Internships, research, and side projects", guides: 5, route: "/guides/experience" },
    { id: "resources",   label: "resources",      desc: "Tools, courses, and reading lists",        guides: 7, route: "/guides/resources" },
  ] as const;

  type NodeDef  = typeof NODE_DEFS[number];
  type NodeDatum = NodeDef & d3.SimulationNodeDatum & { _dist?: number };
  type LinkDatum = { source: string; target: string };

  const links: LinkDatum[] = [
    { source: "wiki", target: "foundations" },
    { source: "wiki", target: "career" },
    { source: "wiki", target: "networking" },
    { source: "wiki", target: "technical" },
    { source: "wiki", target: "experience" },
    { source: "wiki", target: "resources" },
    { source: "foundations", target: "technical" },
    { source: "career",      target: "networking" },
    { source: "career",      target: "experience" },
  ];

  // ── depth helpers ─────────────────────────────────────────────
  // Returns 0 (center) → 1 (far) based on distance from canvas center
  function depthFactor(d: NodeDatum, W: number, H: number): number {
    const dx = (d.x ?? W/2) - W/2;
    const dy = (d.y ?? H/2) - H/2;
    const maxDist = Math.sqrt((W/2)**2 + (H/2)**2);
    return Math.min(Math.sqrt(dx*dx + dy*dy) / maxDist, 1);
  }

  function nodeRadius(d: NodeDatum): number {
    return ("central" in d && d.central) ? 28 : 14;
  }

  // Depth-aware radius: outer nodes are ~15% smaller
  function visualRadius(d: NodeDatum, W: number, H: number): number {
    const base = nodeRadius(d);
    if ("central" in d && d.central) return base;
    const df = depthFactor(d, W, H);
    return base * (1 - df * 0.15);
  }

  // Depth-aware opacity: outer nodes slightly dimmer
  function depthOpacity(d: NodeDatum, W: number, H: number): number {
    if ("central" in d && d.central) return 1;
    const df = depthFactor(d, W, H);
    return 1 - df * 0.35;
  }

  // Parallax shift magnitude for a node — outer nodes move more
  function parallaxStrength(d: NodeDatum, W: number, H: number): number {
    if ("central" in d && d.central) return 0.5;
    const df = depthFactor(d, W, H);
    return 2 + df * 14;
  }

  // ── mount ─────────────────────────────────────────────────────
  const root  = document.getElementById("constellation-root")!;
  const svgEl = document.getElementById("graph-svg") as unknown as SVGSVGElement;
  const tip   = document.getElementById("node-tooltip")!;
  const tipName  = tip.querySelector(".tooltip__name")!;
  const tipDesc  = tip.querySelector(".tooltip__desc")!;
  const tipCount = tip.querySelector(".tooltip__count")!;

  let W = root.clientWidth;
  let H = root.clientHeight;

  const svg = d3.select(svgEl);

  // ── defs: filters + gradients ─────────────────────────────────
  const defs = svg.append("defs");

  // Glow blur filter
  const glowFilter = defs.append("filter")
    .attr("id", "glow")
    .attr("x", "-60%").attr("y", "-60%")
    .attr("width", "220%").attr("height", "220%");
  glowFilter.append("feGaussianBlur").attr("stdDeviation", "5").attr("result", "blur");
  glowFilter.append("feComposite").attr("in", "SourceGraphic").attr("in2", "blur").attr("operator", "over");

  // Hover glow (stronger)
  const hoverFilter = defs.append("filter")
    .attr("id", "glow-hover")
    .attr("x", "-80%").attr("y", "-80%")
    .attr("width", "260%").attr("height", "260%");
  hoverFilter.append("feGaussianBlur").attr("stdDeviation", "10").attr("result", "blur");
  hoverFilter.append("feComposite").attr("in", "SourceGraphic").attr("in2", "blur").attr("operator", "over");

  // Pulse ring soft blur
  const pulseFilter = defs.append("filter")
    .attr("id", "glow-soft")
    .attr("x", "-100%").attr("y", "-100%")
    .attr("width", "300%").attr("height", "300%");
  pulseFilter.append("feGaussianBlur").attr("stdDeviation", "12");

  // Per-node radial gradients — 3D sphere shading (highlight top-left)
  const mutableNodes = NODE_DEFS.map(n => ({ ...n })) as NodeDatum[];

  mutableNodes.forEach(d => {
    const grad = defs.append("radialGradient")
      .attr("id", `grad-${d.id}`)
      .attr("cx", "32%").attr("cy", "28%").attr("r", "68%");

    if ("central" in d && d.central) {
      // White specular → lavender → purple → deep purple
      grad.append("stop").attr("offset",  "0%").attr("stop-color", "#ffffff");
      grad.append("stop").attr("offset", "18%").attr("stop-color", "rgba(232,210,255,1)");
      grad.append("stop").attr("offset", "50%").attr("stop-color", "rgba(168,85,247,1)");
      grad.append("stop").attr("offset", "80%").attr("stop-color", "rgba(76,29,149,1)");
      grad.append("stop").attr("offset","100%").attr("stop-color", "#0f061e");
    } else if ("accent" in d && (d as any).accent) {
      // Cyan sphere
      grad.append("stop").attr("offset",  "0%").attr("stop-color", "#ffffff");
      grad.append("stop").attr("offset", "25%").attr("stop-color", "rgba(186,230,253,1)");
      grad.append("stop").attr("offset", "65%").attr("stop-color", "rgba(34,211,238,1)");
      grad.append("stop").attr("offset","100%").attr("stop-color", "rgba(8,51,68,1)");
    } else {
      // Purple sphere
      grad.append("stop").attr("offset",  "0%").attr("stop-color", "#ffffff");
      grad.append("stop").attr("offset", "22%").attr("stop-color", "rgba(216,180,254,1)");
      grad.append("stop").attr("offset", "60%").attr("stop-color", "rgba(168,85,247,1)");
      grad.append("stop").attr("offset","100%").attr("stop-color", "rgba(76,29,149,1)");
    }
  });

  // ── zoom container ────────────────────────────────────────────
  const g = svg.append("g").attr("class", "zoom-layer");
  const zoom = d3.zoom<SVGSVGElement, unknown>()
    .scaleExtent([0.4, 3])
    .on("zoom", (e) => g.attr("transform", e.transform));
  svg.call(zoom);

  // ── simulation ────────────────────────────────────────────────
  const sim = d3.forceSimulation<NodeDatum>(mutableNodes)
    .force("link",    d3.forceLink<NodeDatum, LinkDatum>(links).id(d => d.id).distance(160).strength(0.6))
    .force("charge",  d3.forceManyBody().strength(-600))
    .force("center",  d3.forceCenter(W / 2, H / 2))
    .force("collide", d3.forceCollide<NodeDatum>().radius(d => nodeRadius(d) + 20))
    .alphaDecay(0.025);

  const centerNode = mutableNodes.find(n => n.id === "wiki")!;
  centerNode.fx = W / 2;
  centerNode.fy = H / 2;
  mutableNodes.forEach(n => { n.x = W / 2; n.y = H / 2; });

  // ── edges ─────────────────────────────────────────────────────
  const linkSel = g.append("g").attr("class", "links")
    .selectAll("line")
    .data(links)
    .join("line")
    .attr("stroke", "rgba(168,85,247,.18)")
    .attr("stroke-width", 1)
    .attr("stroke-dasharray", d => {
      const isSpoke = (d.source as string) === "wiki" || (d.target as string) === "wiki";
      return isSpoke ? "none" : "3 4";
    });

  // ── node groups ───────────────────────────────────────────────
  const nodeG = g.append("g").attr("class", "nodes")
    .selectAll<SVGGElement, NodeDatum>("g")
    .data(mutableNodes)
    .join("g")
    .attr("class", "node-group")
    .style("cursor", d => ("route" in d && (d as any).route) ? "pointer" : "default");

  // Outer glow halo
  nodeG.append("circle")
    .attr("class", "node-halo")
    .attr("r", d => nodeRadius(d) + 14)
    .attr("fill", d => {
      if ("central" in d && d.central) return "rgba(168,85,247,.55)";
      if ("accent" in d && (d as any).accent) return "rgba(34,211,238,.5)";
      return "rgba(168,85,247,.4)";
    })
    .attr("filter", "url(#glow)")
    .attr("opacity", 0.35);

  // Main sphere circle
  nodeG.append("circle")
    .attr("class", "node-sphere")
    .attr("r", d => nodeRadius(d))
    .attr("fill", d => `url(#grad-${d.id})`)
    .attr("stroke", d => {
      if ("central" in d && d.central) return "rgba(216,180,254,.5)";
      if ("accent" in d && (d as any).accent) return "rgba(186,230,253,.4)";
      return "rgba(168,85,247,.4)";
    })
    .attr("stroke-width", 1);

  // Specular highlight — tiny bright ellipse offset top-left for 3D look
  nodeG.append("ellipse")
    .attr("class", "node-specular")
    .attr("cx", d => -nodeRadius(d) * 0.28)
    .attr("cy", d => -nodeRadius(d) * 0.3)
    .attr("rx", d => nodeRadius(d) * 0.28)
    .attr("ry", d => nodeRadius(d) * 0.18)
    .attr("fill", "rgba(255,255,255,.55)")
    .style("pointer-events", "none");

  // Pulse rings — central node only
  const centralG = nodeG.filter(d => "central" in d && !!d.central);
  [0, 1.4, 2.8].forEach(delay => {
    centralG.append("circle")
      .attr("class", "pulse-ring")
      .attr("r", 28)
      .attr("fill", "none")
      .attr("stroke", "rgba(168,85,247,.3)")
      .attr("stroke-width", 1.5)
      .style("animation", `pulseRing 3.6s ease-out ${delay}s infinite`)
      .style("transform-origin", "0 0");
  });

  // Labels
  nodeG.append("text")
    .attr("class", "node-label")
    .attr("dy", d => nodeRadius(d) + 18)
    .attr("text-anchor", "middle")
    .attr("fill", "#fff")
    .attr("font-family", "Georgia, serif")
    .attr("font-style", "italic")
    .attr("font-size", d => ("central" in d && d.central) ? "13px" : "11px")
    .style("text-shadow", "0 0 12px rgba(0,0,0,.9)")
    .style("pointer-events", "none")
    .text(d => d.label);

  // Guide count badge (child nodes only)
  nodeG.filter(d => !("central" in d) || !d.central)
    .append("text")
    .attr("class", "node-count")
    .attr("dy", d => nodeRadius(d) + 30)
    .attr("text-anchor", "middle")
    .attr("fill", d => ("accent" in d && (d as any).accent) ? "rgba(186,230,253,.65)" : "rgba(216,180,254,.6)")
    .attr("font-family", "'SF Mono', Menlo, monospace")
    .attr("font-size", "8px")
    .attr("letter-spacing", "0.12em")
    .style("pointer-events", "none")
    .text(d => `${String((d as any).guides ?? 0).padStart(2,"0")} GUIDES`);

  // ── drag ──────────────────────────────────────────────────────
  const drag = d3.drag<SVGGElement, NodeDatum>()
    .on("start", (e, d) => {
      if (!e.active) sim.alphaTarget(0.3).restart();
      if (!("central" in d) || !d.central) { d.fx = d.x; d.fy = d.y; }
    })
    .on("drag", (e, d) => {
      if (!("central" in d) || !d.central) { d.fx = e.x; d.fy = e.y; }
    })
    .on("end", (e, d) => {
      if (!e.active) sim.alphaTarget(0);
      if (!("central" in d) || !d.central) { d.fx = null; d.fy = null; }
    });

  nodeG.call(drag as any);

  // ── hover & click ─────────────────────────────────────────────
  nodeG
    .on("mouseenter", function(e: MouseEvent, d) {
      if ("central" in d && d.central) return;
      const nd = d as any;
      tipName.textContent  = nd.label;
      tipDesc.textContent  = nd.desc ?? "";
      tipCount.textContent = `${String(nd.guides ?? 0).padStart(2,"0")} GUIDES`;
      tip.classList.add("visible");

      // Scale up + intensify glow
      d3.select(this).select(".node-sphere").transition().duration(180)
        .attr("r", nodeRadius(d) * 1.22);
      d3.select(this).select(".node-halo").transition().duration(180)
        .attr("r", nodeRadius(d) * 1.22 + 18)
        .attr("opacity", 0.6);
      d3.select(this).select(".node-specular").transition().duration(180)
        .attr("rx", d => nodeRadius(d) * 0.35)
        .attr("ry", d => nodeRadius(d) * 0.22);
      d3.select(this).select(".node-sphere")
        .attr("filter", "url(#glow-hover)");
    })
    .on("mousemove", (e: MouseEvent) => {
      tip.style.left = `${e.clientX + 16}px`;
      tip.style.top  = `${e.clientY - 14}px`;
    })
    .on("mouseleave", function(_e, d) {
      tip.classList.remove("visible");
      d3.select(this).select(".node-sphere").transition().duration(200)
        .attr("r", nodeRadius(d))
        .attr("filter", null);
      d3.select(this).select(".node-halo").transition().duration(200)
        .attr("r", nodeRadius(d) + 14)
        .attr("opacity", 0.35);
    })
    .on("click", (_e, d) => {
      if ("route" in d && (d as any).route) window.location.href = (d as any).route;
    });

  // ── tick ──────────────────────────────────────────────────────
  sim.on("tick", () => {
    linkSel
      .attr("x1", d => (d.source as NodeDatum).x!)
      .attr("y1", d => (d.source as NodeDatum).y!)
      .attr("x2", d => (d.target as NodeDatum).x!)
      .attr("y2", d => (d.target as NodeDatum).y!);

    nodeG.attr("transform", d => `translate(${d.x},${d.y})`);

    // Update depth-based size and opacity each tick
    nodeG.each(function(d) {
      const vr  = visualRadius(d, W, H);
      const opc = depthOpacity(d, W, H);
      const sel = d3.select(this);
      if (!("central" in d) || !d.central) {
        sel.select(".node-sphere").attr("r", vr);
        sel.select(".node-halo").attr("r", vr + 14);
        sel.attr("opacity", opc);
      }
    });
  });

  // ── mouse parallax ────────────────────────────────────────────
  // Each layer and each node shifts at a different rate based on depth
  const starsNebula = document.getElementById("layer-nebula")!;
  const starsFar    = document.getElementById("stars-far")!;
  const starsMid    = document.getElementById("stars-mid")!;
  const starsNear   = document.getElementById("stars-near")!;

  let mouseX = 0, mouseY = 0;
  let rafPending = false;

  // Parallax offset for the SVG graph layer (nodes)
  let graphOffsetX = 0, graphOffsetY = 0;

  document.addEventListener("mousemove", (e: MouseEvent) => {
    // Normalized -1 → +1 from center
    mouseX = (e.clientX / W - 0.5) * 2;
    mouseY = (e.clientY / H - 0.5) * 2;

    if (!rafPending) {
      rafPending = true;
      requestAnimationFrame(applyParallax);
    }
  });

  function applyParallax() {
    rafPending = false;

    // Background star layers — each at different depth (far moves least)
    starsNebula.style.transform = `translate(${mouseX * 3}px, ${mouseY * 2}px)`;
    starsFar.style.transform    = `translate(${mouseX * 6}px, ${mouseY * 4}px)`;
    starsMid.style.transform    = `translate(${mouseX * 12}px, ${mouseY * 8}px)`;
    starsNear.style.transform   = `translate(${mouseX * 20}px, ${mouseY * 14}px)`;

    // Shift the entire SVG graph group slightly — nodes will deviate further based on their depth
    graphOffsetX = mouseX * 8;
    graphOffsetY = mouseY * 6;

    // Apply per-node parallax offset on top of simulation position
    nodeG.attr("transform", d => {
      const strength = parallaxStrength(d, W, H);
      const px = mouseX * strength;
      const py = mouseY * strength;
      return `translate(${(d.x ?? W/2) + px}, ${(d.y ?? H/2) + py})`;
    });

    // Also shift link endpoints with a modest offset
    linkSel
      .attr("x1", d => {
        const src = d.source as NodeDatum;
        const str = parallaxStrength(src, W, H) * 0.5;
        return (src.x ?? 0) + mouseX * str;
      })
      .attr("y1", d => {
        const src = d.source as NodeDatum;
        const str = parallaxStrength(src, W, H) * 0.5;
        return (src.y ?? 0) + mouseY * str;
      })
      .attr("x2", d => {
        const tgt = d.target as NodeDatum;
        const str = parallaxStrength(tgt, W, H) * 0.5;
        return (tgt.x ?? 0) + mouseX * str;
      })
      .attr("y2", d => {
        const tgt = d.target as NodeDatum;
        const str = parallaxStrength(tgt, W, H) * 0.5;
        return (tgt.y ?? 0) + mouseY * str;
      });
  }

  // ── resize ────────────────────────────────────────────────────
  window.addEventListener("resize", () => {
    W = root.clientWidth;
    H = root.clientHeight;
    centerNode.fx = W / 2;
    centerNode.fy = H / 2;
    sim.force("center", d3.forceCenter(W / 2, H / 2)).alpha(0.3).restart();
  });
</script>

<style is:global>
  @keyframes pulseRing {
    0%   { transform: scale(1);   opacity: .55; }
    100% { transform: scale(2.8); opacity: 0;   }
  }
</style>
