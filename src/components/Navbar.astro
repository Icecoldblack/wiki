---
import { NAV_LINKS } from "../consts";
---

<nav class="hero-nav">
  <div class="hero-nav__logo">
    <div class="hero-nav__orb"></div>
    <span class="hero-nav__title">progsu / wiki</span>
  </div>
  <div class="hero-nav__links">
    <a href="/" class="hero-nav__link">start</a>
    {NAV_LINKS.map((l) => (
      <a href={l.href} class="hero-nav__link">{l.label.toLowerCase()}</a>
    ))}
    <a href="https://github.com/progsu" class="hero-nav__link">contribute</a>
    <span class="hero-nav__kbd">/</span>
  </div>
</nav>

<style>
  .hero-nav {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    right: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 30;
  }

  .hero-nav__logo {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .hero-nav__orb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(216,180,254,1) 0%, rgba(168,85,247,1) 50%, rgba(76,29,149,1) 100%);
    box-shadow: 0 0 8px rgba(168, 85, 247, .6);
  }

  .hero-nav__title {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .6rem;
    color: rgba(255, 255, 255, .65);
    letter-spacing: .15em;
  }

  .hero-nav__links {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .55rem;
    letter-spacing: .12em;
  }

  .hero-nav__link {
    color: rgba(255, 255, 255, .5);
    text-decoration: none;
    transition: color .2s;
  }
  .hero-nav__link:hover { color: rgba(255, 255, 255, .9); }

  .hero-nav__kbd {
    border: 1px solid rgba(255, 255, 255, .18);
    padding: .2rem .4rem;
    border-radius: .25rem;
    color: rgba(255, 255, 255, .7);
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .55rem;
    letter-spacing: .12em;
  }
</style>
