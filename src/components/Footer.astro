---
import { SITE_TITLE } from "../consts";
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__orb"></div>
    <span class="site-footer__text">&copy; {new Date().getFullYear()} {SITE_TITLE} &middot; built by progsu &middot; open on github</span>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(168,85,247,.12);
    padding: 2rem 1.5rem;
    margin-top: 4rem;
  }

  .site-footer__inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
  }

  .site-footer__orb {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(216,180,254,1), rgba(168,85,247,1) 60%, rgba(76,29,149,1));
    box-shadow: 0 0 6px rgba(168,85,247,.6);
    flex-shrink: 0;
  }

  .site-footer__text {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .48rem;
    color: rgba(255,255,255,.28);
    letter-spacing: .18em;
  }
</style>
