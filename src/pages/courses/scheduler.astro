---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CoursesSubnav from "../../components/CoursesSubnav.astro";

const DAYS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'] as const;
const START_HOUR = 7;
const END_HOUR = 21;
const SLOTS = (END_HOUR - START_HOUR) * 2;

function timeLabel(slot: number) {
  const totalMin = START_HOUR * 60 + slot * 30;
  const h = Math.floor(totalMin / 60);
  const m = totalMin % 60;
  const suffix = h >= 12 ? 'p' : 'a';
  const h12 = h > 12 ? h - 12 : h === 0 ? 12 : h;
  return m === 0 ? `${h12}${suffix}` : '';
}
function isHourSlot(slot: number) { return slot % 2 === 0; }
---

<Layout title="Scheduler — Courses" wide>
  <Breadcrumb items={[
    { label: "courses", href: "/courses" },
    { label: "scheduler" },
  ]} />

  <CoursesSubnav active="scheduler" />

  <!-- ── Top bar ── -->
  <div class="sched-topbar">
    <div class="topbar__left">
      <div class="topbar__picker" id="schedule-picker">
        <button class="topbar__active-schedule surface-glass" id="schedule-picker-btn" aria-haspopup="listbox">
          <span class="topbar__sched-name" id="active-sched-name">Ideal</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="topbar__dropdown surface-glass surface-glass--strong" id="schedule-dropdown">
          <div class="dropdown__list" id="dropdown-list"></div>
          <button class="dropdown__new" id="new-schedule-btn">+ New schedule</button>
          <a class="dropdown__compare" href="/courses/compare">Compare schedules</a>
        </div>
      </div>
      <span class="topbar__name" contenteditable="true" spellcheck="false" id="sched-name">Fall 2026</span>
      <select class="topbar__semester surface-glass" aria-label="Semester" id="semester-select">
        <option>Fall 2026</option>
        <option>Spring 2027</option>
        <option>Summer 2027</option>
      </select>
    </div>
    <div class="topbar__right">
      <span class="topbar__save" id="sched-save-dot" title="Saved">
        <span class="save-dot"></span>
        <span class="save-label">saved</span>
      </span>
      <div class="topbar__export" id="export-wrap">
        <button class="topbar__export-btn surface-glass" id="export-btn" aria-haspopup="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          <span>export</span>
        </button>
        <div class="export-menu surface-glass surface-glass--strong" id="export-menu">
          <button class="export-menu__item" id="export-ics">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>download .ics</span>
          </button>
          <button class="export-menu__item" id="export-print">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            <span>print</span>
          </button>
          <button class="export-menu__item" id="export-share">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span>copy share link</span>
          </button>
        </div>
      </div>
      <button class="topbar__add surface-glass" id="add-course-btn">+ add course</button>
    </div>
  </div>

  <!-- Slide-in panel backdrop -->
  <div class="add-backdrop" id="add-backdrop"></div>

  <!-- Slide-in panel -->
  <aside class="add-panel surface-glass surface-glass--strong" id="add-panel">
    <div class="add-panel__header">
      <h3 class="add-panel__title">add a course</h3>
      <button class="add-panel__close" id="add-panel-close" aria-label="Close">&times;</button>
    </div>

    <div class="add-panel__section" id="add-saved-section">
      <h4 class="add-panel__label">saved</h4>
      <div class="add-panel__list" id="add-saved-list">
        <p class="add-panel__empty">no starred courses. <a href="/courses" class="add-panel__link">browse courses</a></p>
      </div>
    </div>

    <div class="add-panel__section">
      <h4 class="add-panel__label">all courses</h4>
      <input class="add-panel__search" id="add-search" type="text" placeholder="search courses..." autocomplete="off" spellcheck="false" aria-label="Search courses to add" />
      <div class="add-panel__list" id="add-browse-list"></div>
    </div>
  </aside>

  <!-- Toast container -->
  <div class="toast-container" id="toast-container"></div>

  <!-- ── Onboarding hint ── -->
  <div class="onboarding-hint surface-glass" id="onboarding-hint" style="display:none">
    <p class="onboarding-hint__text">
      star courses while browsing, then add them here.
    </p>
    <button class="onboarding-hint__dismiss" id="onboarding-dismiss" aria-label="Dismiss">&times;</button>
  </div>

  <!-- ── Main layout ── -->
  <div class="sched-layout">

    <!-- Mobile day view (hidden on desktop) -->
    <div class="mobile-day-view" id="mobile-day-view">
      <div class="day-pills" id="day-pills" role="tablist" aria-label="Day selector">
        <button class="day-pill active" data-day="Mon" role="tab" aria-selected="true" aria-label="Monday" tabindex="0">M</button>
        <button class="day-pill" data-day="Tue" role="tab" aria-selected="false" aria-label="Tuesday" tabindex="-1">T</button>
        <button class="day-pill" data-day="Wed" role="tab" aria-selected="false" aria-label="Wednesday" tabindex="-1">W</button>
        <button class="day-pill" data-day="Thu" role="tab" aria-selected="false" aria-label="Thursday" tabindex="-1">R</button>
        <button class="day-pill" data-day="Fri" role="tab" aria-selected="false" aria-label="Friday" tabindex="-1">F</button>
      </div>
      <div class="day-timeline" id="day-timeline" role="tabpanel" aria-label="Classes for selected day"></div>
      <div class="day-empty" id="day-empty" style="display:none">
        <p>no classes this day.</p>
      </div>
    </div>

    <!-- Weekly grid -->
    <div class="sched-grid-wrap">
      <div class="sched-grid" style={`--rows: ${SLOTS}; --cols: ${DAYS.length}`}>
        <!-- Day headers -->
        <div class="grid-corner"></div>
        {DAYS.map(d => (
          <div class="grid-day-header">{d}</div>
        ))}

        <!-- Time rows + cells -->
        {Array.from({ length: SLOTS }).map((_, slot) => (
          <Fragment>
            <div class:list={['grid-time', { 'grid-time--labeled': timeLabel(slot), 'grid-time--hour': isHourSlot(slot) }]}>
              {timeLabel(slot) && <span>{timeLabel(slot)}</span>}
            </div>
            {DAYS.map(day => (
              <div class:list={['grid-cell', { 'grid-cell--hour': isHourSlot(slot) }]} data-day={day} data-slot={slot}></div>
            ))}
          </Fragment>
        ))}
      </div>
      <div class="block-overlay" id="block-overlay"></div>
    </div>

    <!-- Right panel -->
    <aside class="sched-panel">
      <!-- Skeleton (visible until JS hydrates) -->
      <div class="skel-wrap panel-bubble surface-glass" id="panel-skel">
        <div class="panel-section">
          <h3 class="panel-label">courses</h3>
          <div class="panel-courses" style="margin-top: var(--space-4)">
            {Array.from({ length: 3 }).map(() => (
              <div class="panel-skel-row">
                <div class="skel" style="width:6px;height:6px;border-radius:50%;flex-shrink:0"></div>
                <div style="flex:1;display:flex;flex-direction:column;gap:2px">
                  <div class="skel skel-line" style="width:60px;height:0.5rem"></div>
                  <div class="skel skel-line skel-line--med" style="height:0.6rem"></div>
                </div>
                <div class="skel skel-line" style="width:24px;height:0.5rem"></div>
              </div>
            ))}
          </div>
        </div>
        <div class="panel-summary">
          <div class="skel skel-line" style="width:50px;height:1.2rem;margin-bottom:var(--space-3)"></div>
          <div class="skel skel-line" style="width:100%;height:0.6rem"></div>
        </div>
      </div>

      <!-- Real content (hidden until JS hydrates) -->
      <div class="panel-bubble surface-glass" id="panel-live" style="display:none">
        <div class="panel-section">
          <h3 class="panel-label">courses</h3>
          <div class="panel-courses" id="panel-courses"></div>

          <!-- Empty schedule state -->
          <div class="panel-empty" id="panel-empty" style="display:none">
            <p class="panel-empty__text">nothing scheduled yet.</p>
          </div>
        </div>

        <div class="panel-summary" id="panel-summary">
          <div class="summary-hero" id="summary-hero"></div>
          <div class="summary-meta" id="summary-meta"></div>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<style>
  /* ── Top bar ── */
  .sched-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .topbar__left {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    min-width: 0;
  }

  /* ── Schedule picker dropdown ── */
  .topbar__picker {
    position: relative;
  }

  .topbar__active-schedule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-text-primary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease);
    min-width: 0;
  }
  .topbar__sched-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .topbar__active-schedule:hover,
  .topbar__active-schedule[aria-expanded="true"] {
    border-color: var(--glass-border-hi);
  }
  .topbar__active-schedule svg {
    color: var(--color-text-muted);
    transition: transform var(--duration-fast) var(--ease);
  }
  .topbar__active-schedule[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .topbar__dropdown {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    width: max(220px, 100%);
    max-width: calc(100vw - var(--space-8));
    border-radius: var(--radius-lg);
    padding: var(--space-2);
    display: none;
    flex-direction: column;
    gap: var(--space-1);
    z-index: var(--z-overlay);
    box-shadow: var(--glass-shadow);
  }
  .topbar__dropdown.open {
    display: flex;
  }

  .dropdown__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  :global(.dropdown__item) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease);
  }
  :global(.dropdown__item):hover {
    background: rgba(255, 255, 255, 0.04);
  }
  :global(.dropdown__item.active) {
    background: var(--accent-subtle);
  }

  :global(.dropdown__item-name) {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.dropdown__item-meta) {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    flex-shrink: 0;
  }

  :global(.dropdown__item-delete) {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    cursor: pointer;
    padding: 0 var(--space-1);
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease), color var(--duration-fast) var(--ease);
    flex-shrink: 0;
  }
  :global(.dropdown__item):hover :global(.dropdown__item-delete) {
    opacity: 1;
  }
  :global(.dropdown__item-delete):hover {
    color: #f87171;
  }

  .dropdown__new,
  .dropdown__compare {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease);
    text-align: left;
    background: none;
    border: none;
    text-decoration: none;
    display: block;
  }
  .dropdown__new {
    color: var(--accent-text);
    border-top: 1px solid var(--glass-border);
    margin-top: var(--space-1);
    padding-top: var(--space-3);
  }
  .dropdown__compare {
    color: var(--color-text-muted);
  }
  .dropdown__new:hover,
  .dropdown__compare:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .topbar__name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-text-primary);
    outline: none;
    border-bottom: 1px dashed transparent;
    padding: var(--space-1) 0;
    cursor: text;
    transition: border-color var(--duration-fast) var(--ease);
    display: none;
  }

  .topbar__semester {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    outline: none;
  }
  .topbar__semester option {
    background: var(--color-bg-raised);
    color: var(--color-text-secondary);
  }

  .topbar__right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .topbar__save {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .save-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: #34d399;
    box-shadow: 0 0 6px rgba(52, 211, 153, 0.5);
  }

  .save-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
  }

  /* ── Onboarding hint ── */
  .onboarding-hint {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-6);
    border-color: var(--accent-border);
  }

  .onboarding-hint__text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    margin: 0;
  }
  .onboarding-hint__text em {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--accent-light);
  }

  .onboarding-hint__dismiss {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    cursor: pointer;
    padding: var(--space-1);
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease);
  }
  .onboarding-hint__dismiss:hover {
    color: var(--color-text-primary);
  }

  /* ── Empty schedule state ── */
  .panel-empty {
    margin-top: var(--space-4);
    text-align: center;
    padding: var(--space-6) var(--space-4);
  }

  .panel-empty__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin: 0 0 var(--space-2);
  }

  .panel-empty__hint {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* ── Panel skeleton ── */
  .skel-wrap {
    transition: opacity var(--duration-normal) var(--ease);
  }
  .skel-wrap.hidden {
    display: none;
  }

  .panel-skel-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--glass-border);
  }
  .panel-skel-row:last-child {
    border-bottom: none;
  }

  /* ── Main layout ── */
  .sched-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    grid-template-rows: auto;
    gap: var(--space-8);
    align-items: start;
  }

  /* ── Weekly grid ── */
  .sched-grid-wrap {
    overflow: hidden;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    grid-column: 1;
    grid-row: 1;
    position: relative;
  }

  .block-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }
  .block-overlay :global(.sched-block) {
    pointer-events: auto;
  }

  .sched-grid {
    display: grid;
    grid-template-columns: 40px repeat(var(--cols), 1fr);
    grid-template-rows: 32px repeat(var(--rows), 20px);
    position: relative;
    min-width: 500px;
  }

  .grid-corner {
    grid-column: 1;
    grid-row: 1;
    background: var(--glass-bg-strong);
    border-bottom: 1px solid var(--color-border-subtle);
    border-right: 1px solid var(--color-border-subtle);
  }

  .grid-day-header {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    background: var(--glass-bg-strong);
    border-bottom: 1px solid var(--color-border-subtle);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .grid-day-header:last-of-type {
    border-right: none;
  }

  .grid-time {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-right: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    border-right: 1px solid var(--color-border-subtle);
    position: relative;
  }
  .grid-time > span {
    transform: translateY(-0.35em);
  }
  .grid-time--hour {
    border-top: 1px solid var(--glass-border);
  }

  .grid-cell {
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .grid-cell--hour {
    border-top: 1px solid var(--glass-border);
  }

  /* ── Course blocks (dynamically created — :global needed) ── */
  :global(.sched-block) {
    position: absolute;
    box-sizing: border-box;
    border-radius: 0;
    border: 1px solid;
    padding: 2px 4px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 1px;
    overflow: hidden;
    cursor: pointer;
    z-index: 2;
    transition: box-shadow var(--duration-fast) var(--ease);
  }
  :global(.sched-block):hover {
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.15);
  }

  :global(.sched-block__code) {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--block-text);
    letter-spacing: var(--tracking-wider);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    text-align: center;
  }

  :global(.sched-block__room) {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    text-align: center;
  }

  /* ── Block popover (dynamically created) ── */
  :global(.block-popover) {
    position: fixed;
    z-index: var(--z-overlay);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.block-popover__code) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-light);
    letter-spacing: var(--tracking-wider);
  }

  :global(.block-popover__title) {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-text-primary);
  }

  :global(.block-popover__meta) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
