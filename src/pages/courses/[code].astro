    prereqs: [{ code: "MATH 2212", slug: "math-2212" }],
    sections: [
      { id: "001", professor: "Dr. Gupta", days: "MW", time: "11:00–12:15", room: "Classroom S 210", seats: 14, cap: 25 },
      { id: "002", professor: "Dr. Gupta", days: "MW", time: "3:30–4:45", room: "Classroom S 210", seats: 18, cap: 25 },
    ],
    notes: [],
    related: ["math-2212", "math-2641"],
  },
};
  return Object.keys(courses).map(key => ({
    params: { code: key },
    props: { course: courses[key], courses },
  }));
}

const { course, courses: all } = Astro.props as any;

function deriveTimeOfDay(time: string): string {
  const match = time.match(/(\d{1,2}):/);
  if (!match) return 'morning';
  const hour = Number(match[1]);
  if (hour < 12) return 'morning';
  if (hour < 17) return 'afternoon';
  return 'evening';
}

const subjectLabel = course.subject;
const relatedCourses = (course.related ?? [])
  .map((slug: string) => all[slug])
  .filter(Boolean)
  .slice(0, 3);

---

<Layout title={`${course.code} — ${course.title}`}>
  <Breadcrumb items={[
    { label: "courses", href: "/courses" },
    { label: subjectLabel, href: "/courses" },
    { label: course.code },
  ]} />

  <!-- ── Hero ── -->
  <header class="course-hero">
    <span class="hero__code">{course.code}</span>
    <h1 class="hero__title">{course.title}</h1>
    <p class="hero__desc">{course.description.split('.')[0]}.</p>
    <div class="hero__actions">
      <button class="hero__cta hero__cta--primary surface-glass">add to schedule</button>
      <button class="hero__cta hero__cta--secondary surface-glass" data-save-code={course.code} aria-pressed="false">save for later</button>
    </div>
    <div class="hero__meta">
      <span class="hero__pill">{course.credits} credits</span>
      <span class="hero__pill">{course.level}-level</span>
      <span class="hero__pill">offered {(course.semesters ?? []).join(' · ')}</span>
      {course.notes.length > 0 && <span class="hero__pill hero__pill--accent">ProgSU notes</span>}
    </div>
  </header>

  <!-- ── What is this? ── -->
  <section class="detail-section">
    <h2 class="section-heading">about</h2>
    <p class="section-body">{course.description}</p>
    {course.outcomes.length > 0 && (
      <ul class="outcomes">
        {course.outcomes.map((o: string) => <li>{o}</li>)}
      </ul>
    )}
  </section>

  <!-- ── Can I take it? ── -->
  <section class="detail-section">
    <h2 class="section-heading">prerequisites</h2>
    {course.prereqs.length === 0 ? (
      <p class="section-body section-body--calm">none — register directly.</p>
    ) : (
      <div class="prereq-chips">
        {course.prereqs.map((p: any) => (
          <a href={`/courses/${p.slug}`} class="prereq-chip surface-glass">{p.code}</a>
        ))}
      </div>
    )}
  </section>

  <!-- ── When? ── -->
  <section class="detail-section">
    <h2 class="section-heading">sections</h2>

    <div class="sec-filters" role="group" aria-label="Section filters">
      <div class="sec-filter-group" role="group" aria-label="Time of day">
        <button class="sec-filter-chip" data-filter-time="morning">morning</button>
        <button class="sec-filter-chip" data-filter-time="afternoon">afternoon</button>
        <button class="sec-filter-chip" data-filter-time="evening">evening</button>
      </div>
      <label class="sec-filter-toggle">
        <input type="checkbox" id="sec-open-only" />
        <span class="sec-filter-toggle__label">open only</span>
      </label>
    </div>

    <div class="sections-table-wrap">
      <table class="sections-table" id="sections-table">
        <thead>
          <tr>
            <th>section</th>
            <th>professor</th>
            <th>days</th>
            <th>time</th>
            <th>room</th>
            <th>seats</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {course.sections.map((s: any) => (
              <tr data-section-row data-time={deriveTimeOfDay(s.time)} data-days={s.days} data-seats={String(s.seats)}>
                <td class="cell-mono">{s.id}</td>
                <td>{s.professor}</td>
                <td class="cell-mono">{s.days}</td>
                <td class="cell-mono">{s.time}</td>
                <td>{s.room}</td>
                <td>
                  <span class="seat-badge">
                    <span class:list={['seat-dot', s.seats <= 0 ? 'seat-dot--full' : s.seats <= 5 ? 'seat-dot--low' : 'seat-dot--open']} aria-hidden="true"></span>
                    {s.seats}/{s.cap}
                    <span class="sr-only">{s.seats <= 0 ? 'section full' : s.seats <= 5 ? 'seats low' : 'seats available'}</span>
                  </span>
                </td>
                <td>
                  {s.seats <= 0
                    ? <button class="add-btn" disabled>full</button>
                    : <button class="add-btn">+ add</button>
                  }
                </td>
              </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="sec-empty" id="sec-empty" style="display:none">no sections match these filters.</p>
  </section>

  <!-- ── Is it good? ── -->
  <section class="detail-section">
    <h2 class="section-heading">member notes</h2>
    {course.notes.length > 0 ? (
      <div class="notes-grid">
        {course.notes.map((n: any) => (
          <div class="note-card surface-glass">
            <p class="note-card__text">"{n.text}"</p>
            <div class="note-card__footer">
              <span class="note-card__author">{n.author}</span>
              <span class="note-card__date">{n.date}</span>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-notes surface-glass">
        <p class="empty-notes__text">no notes yet.</p>
        <p class="empty-notes__invite">taken it? your experience helps the next student.</p>
      </div>
    )}
  </section>

  <!-- ── What's similar? ── -->
  {relatedCourses.length > 0 && (
    <section class="detail-section">
      <h2 class="section-heading">related</h2>
      <div class="related-grid">
        {relatedCourses.map((r: any) => (
          <a href={`/courses/${r.code.toLowerCase().replace(' ', '-')}`} class="related-card surface-glass">
            <span class="related-card__code">{r.code}</span>
            <span class="related-card__title">{r.title}</span>
            <span class="related-card__credits">{r.credits} credits</span>
          </a>
        ))}
      </div>
    </section>
  )}
  <footer class="course-footer">
    <span class="course-footer__text">missing a professor or note?</span>
    <a href="https://github.com/ProgSU/wiki" class="course-footer__link">edit on github &rarr;</a>
  </footer>

  <PlanWiring />
</Layout>

<style>
