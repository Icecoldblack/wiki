---
import { SITE_TITLE } from "../consts";
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="site-footer__orb" aria-hidden="true"></div>
    <p class="site-footer__text">
      &copy; {new Date().getFullYear()} {SITE_TITLE} &middot; built by progsu &middot;
      <a href="https://github.com/progsu-official" class="site-footer__link" rel="noopener noreferrer">
        open on github
      </a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: var(--z-base);
    border-top: 1px solid var(--accent-border);
    padding: var(--space-10) var(--page-gutter);
    margin-top: auto;
  }

  .site-footer__inner {
    max-width: var(--page-width-wide);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .site-footer__orb {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      var(--color-purple-300),
      var(--color-purple-500) 60%,
      var(--color-purple-900)
    );
    box-shadow: 0 0 6px rgba(168, 85, 247, 0.6);
    flex-shrink: 0;
  }

  .site-footer__text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    margin: 0;
  }

  .site-footer__link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease);
  }
  .site-footer__link:hover {
    color: var(--color-text-tertiary);
  }
</style>
