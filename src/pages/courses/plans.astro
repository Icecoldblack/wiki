---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CoursesSubnav from "../../components/CoursesSubnav.astro";
import Zone from "../../components/courses/Zone.astro";
---

<Layout title="Semester Plans — Courses">
  <Breadcrumb items={[
    { label: "courses", href: "/courses" },
    { label: "plans" },
  ]} />

  <CoursesSubnav active="plans" />

  <PageHeader
    eyebrow="Semester Plans"
    headline="start from something<br>that already worked."
    subline="Pre-built schedules from ProgSU members. Copy one as a starting point, then make it yours."
  />

  <section class="plans">
    <div class="plan surface-glass">
      <div class="plan__head">
        <span class="plan__title">typical CS sophomore fall</span>
        <span class="plan__meta">5 courses &middot; 15 credits</span>
      </div>
      <p class="plan__desc">The standard second-year load. Data structures, calc II, and the first real systems class.</p>
      <Zone label="course list preview &middot; 5 course pills" height="48px" />
      <Zone label="copy to my schedule button" height="44px" />
    </div>

    <div class="plan surface-glass">
      <div class="plan__head">
        <span class="plan__title">catch-up summer</span>
        <span class="plan__meta">3 courses &middot; 9 credits</span>
      </div>
      <p class="plan__desc">Behind on math or science credits? This clears the backlog without burning out.</p>
      <Zone label="course list preview &middot; 3 course pills" height="48px" />
      <Zone label="copy to my schedule button" height="44px" />
    </div>

    <div class="plan surface-glass" style="opacity: 0.55">
      <div class="plan__head">
        <span class="plan__title">senior capstone spring</span>
        <span class="plan__meta">4 courses &middot; 13 credits</span>
      </div>
      <p class="plan__desc">Capstone, one elective, and the last gen-ed. Light enough to job-hunt alongside.</p>
      <Zone label="course list preview &middot; 4 course pills" height="48px" />
      <Zone label="copy to my schedule button" height="44px" />
    </div>
  </section>
</Layout>

<style>
  .plans {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .plan {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-8);
    border-radius: var(--radius-lg);
  }

  .plan__head {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .plan__title {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-text-primary);
  }

  .plan__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
  }

  .plan__desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 480px;
  }

  @media (max-width: 480px) {
    .plan {
      padding: var(--space-5) var(--space-5);
    }
  }
</style>
