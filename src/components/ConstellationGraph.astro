---
// True 3D constellation graph — Three.js spheres, D3 force layout, CSS2D labels
---

<div id="constellation-root">
  <!-- Parallax star layers (CSS, behind WebGL canvas) -->
  <div class="layer-nebula" id="layer-nebula"></div>
  <div class="layer-stars layer-stars--far"  id="stars-far"></div>
  <div class="layer-stars layer-stars--mid"  id="stars-mid"></div>
  <div class="layer-stars layer-stars--near" id="stars-near"></div>
  <div class="vignette"></div>

  <!-- Three.js WebGL canvas -->
  <canvas id="graph-canvas"></canvas>

  <!-- CSS2DRenderer mounts labels here -->
  <div id="label-layer"></div>

  <!-- Hover tooltip -->
  <div id="node-tooltip" class="tooltip" aria-hidden="true">
    <span class="tooltip__name"></span>
    <span class="tooltip__desc"></span>
    <span class="tooltip__count"></span>
  </div>

  <!-- Eyebrow — floats near top of viewport -->
  <div class="hero-eyebrow-wrap">
    <p class="hero-eyebrow">AN OPEN WIKI &middot; BY PROGSU</p>
  </div>

  <!-- Headline + sub — floats in lower-middle -->
  <div class="hero-headline-wrap">
    <h1 class="hero-headline">the open wiki for<br>breaking into tech.</h1>
    <p class="hero-sub">
      knowledge from people who landed offers in quant, big tech, research, and beyond. signed, dated, free. take what helps.
    </p>
  </div>

  <!-- Search bar — lower third, expands inline on activation -->
  <div class="hero-search-wrap">
    <div id="search-bar" class="search-bar">
      <div class="search-icon"><div class="search-handle"></div></div>
      <input id="search-input" class="search-bar__input" type="text" placeholder="search 40 guides, 120 courses" autocomplete="off" spellcheck="false" />
      <span id="search-kbd" class="search-kbd">/</span>
    </div>
    <ul id="search-results" class="search-bar__results"></ul>
    <p class="search-proof">40 GUIDES &middot; 14 AUTHORS &middot; OPEN ON GITHUB</p>
  </div>

  <div class="controls-hint">
    drag · rotate &nbsp;|&nbsp; right-drag · pan &nbsp;|&nbsp; scroll · zoom &nbsp;|&nbsp; dbl-click · reset
  </div>
</div>

<style>
  #constellation-root {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background: #06060f;
  }

  .layer-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 45%, rgba(76,29,149,.35), transparent 70%),
      radial-gradient(ellipse 50% 40% at 20% 75%, rgba(30,27,75,.5),   transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(13,42,90,.4),   transparent 65%),
      linear-gradient(180deg, #02020a 0%, #050516 50%, #02020a 100%);
    will-change: transform;
  }

  .layer-stars { position: absolute; inset: 0; will-change: transform; }

  .layer-stars--far {
    background-image:
      radial-gradient(1px 1px at 12% 23%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 78% 67%, rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 34% 81%, rgba(255,255,255,.45), transparent),
      radial-gradient(1px 1px at 88% 14%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 5%  55%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 65% 30%, rgba(255,255,255,.3), transparent),
      radial-gradient(1px 1px at 25% 8%,  rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 95% 88%, rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 45% 18%, rgba(255,255,255,.3), transparent),
      radial-gradient(1px 1px at 15% 75%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 55% 92%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 38% 45%, rgba(255,255,255,.25), transparent);
    background-size: 280px 280px;
    animation: driftFar 180s linear infinite;
    opacity: .7;
  }

  .layer-stars--mid {
    background-image:
      radial-gradient(1.5px 1.5px at 22% 33%, rgba(255,255,255,.7), transparent),
      radial-gradient(1.5px 1.5px at 68% 57%, rgba(216,180,254,.6), transparent),
      radial-gradient(1.5px 1.5px at 84% 31%, rgba(255,255,255,.65), transparent),
      radial-gradient(1.5px 1.5px at 8%  65%, rgba(255,255,255,.6), transparent),
      radial-gradient(1.5px 1.5px at 92% 78%, rgba(186,230,253,.55), transparent),
      radial-gradient(1.5px 1.5px at 48% 88%, rgba(255,255,255,.5), transparent),
      radial-gradient(1.5px 1.5px at 33% 12%, rgba(255,255,255,.55), transparent),
      radial-gradient(1.5px 1.5px at 72% 8%,  rgba(216,180,254,.5), transparent);
    background-size: 380px 380px;
    animation: driftMid 120s linear infinite;
    opacity: .85;
  }

  .layer-stars--near {
    background-image:
      radial-gradient(2px 2px at 18% 73%, rgba(255,255,255,.95) 0%, rgba(255,255,255,.4) 30%, transparent 60%),
      radial-gradient(2px 2px at 73% 22%, rgba(216,180,254,.85) 0%, rgba(216,180,254,.3) 30%, transparent 60%),
      radial-gradient(2px 2px at 87% 84%, rgba(255,255,255,.9) 0%, rgba(255,255,255,.35) 30%, transparent 60%),
      radial-gradient(2px 2px at 6%  26%, rgba(186,230,253,.8) 0%, rgba(186,230,253,.3) 30%, transparent 60%);
    background-size: 480px 480px;
    animation: driftNear 80s linear infinite;
    opacity: .9;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 95% 80% at 50% 50%, transparent 40%, rgba(0,0,0,.65) 95%);
    pointer-events: none;
    z-index: 2;
  }

  #graph-canvas {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    z-index: 5;
  }

  /* CSS2DRenderer label container */
  #label-layer {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    overflow: hidden;
  }

  /* CSS2DRenderer label container — placeholder, styles moved to is:global below */

  /* Tooltip */
  .tooltip {
    position: fixed;
    padding: .65rem .9rem;
    background: rgba(6,6,18,.9);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(168,85,247,.4);
    border-radius: .5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity .15s;
    z-index: 50;
    display: flex;
    flex-direction: column;
    gap: .2rem;
    box-shadow: 0 0 24px rgba(168,85,247,.2), 0 8px 32px rgba(0,0,0,.6);
  }
  .tooltip.visible { opacity: 1; }
  .tooltip__name {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: .8rem;
    color: #fff;
  }
  .tooltip__desc {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .58rem;
    color: rgba(216,180,254,.7);
    white-space: normal;
    max-width: 200px;
    line-height: 1.5;
  }
  .tooltip__count {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .52rem;
    color: rgba(255,255,255,.3);
    letter-spacing: .12em;
    margin-top: .1rem;
  }

  /* ── hero copy ─────────────────────────────────────────────── */
  .hero-eyebrow-wrap,
  .hero-headline-wrap,
  .hero-search-wrap {
    transition: opacity .6s ease;
  }

  #constellation-root.graph-focused .hero-eyebrow-wrap,
  #constellation-root.graph-focused .hero-headline-wrap,
  #constellation-root.graph-focused .hero-search-wrap {
    opacity: 0;
    pointer-events: none;
  }

  /* '/' key — only search bar peeks back through */
  #constellation-root.graph-focused.search-open .hero-search-wrap {
    opacity: 1;
    pointer-events: all;
  }

  .hero-eyebrow-wrap {
    position: absolute;
    top: 14%;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 20;
    pointer-events: none;
  }

  .hero-eyebrow {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .55rem;
    color: rgba(216,180,254,.85);
    letter-spacing: .25em;
    margin: 0;
    text-shadow: 0 0 18px rgba(0,0,0,.9);
  }

  .hero-headline-wrap {
    position: absolute;
    bottom: 23%;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 20;
    pointer-events: none;
    padding: 0 1.5rem;
  }

  .hero-headline {
    font-family: Georgia, serif;
    font-style: italic;
    color: #fff;
    font-size: clamp(1.6rem, 3.2vw, 2rem);
    line-height: 1.05;
    letter-spacing: -.01em;
    text-shadow: 0 2px 24px rgba(0,0,0,.85), 0 0 40px rgba(76,29,149,.4);
    max-width: 560px;
    margin: 0 auto .85rem;
  }

  .hero-sub {
    font-family: Georgia, serif;
    font-size: .7rem;
    color: rgba(255,255,255,.7);
    line-height: 1.55;
    max-width: 420px;
    margin: 0 auto;
    text-shadow: 0 1px 8px rgba(0,0,0,.85);
  }

  .hero-search-wrap {
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translateX(-50%);
    width: 88%;
    max-width: 480px;
    z-index: 20;
    pointer-events: none;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: .6rem;
    background: rgba(8,8,18,.6);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(168,85,247,.35);
    border-radius: .55rem;
    padding: .65rem .9rem;
    width: 100%;
    box-shadow: 0 0 32px rgba(168,85,247,.15), 0 8px 32px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.06);
    pointer-events: all;
    cursor: text;
  }

  .search-icon {
    width: 10px;
    height: 10px;
    border: 1.5px solid rgba(216,180,254,.7);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .search-handle {
    position: absolute;
    bottom: -3px;
    right: -3px;
    width: 4px;
    height: 1.5px;
    background: rgba(216,180,254,.7);
    transform: rotate(45deg);
    border-radius: 1px;
  }

  .search-bar__input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .7rem;
    color: rgba(255,255,255,.9);
    caret-color: rgba(168,85,247,.9);
    min-width: 0;
  }
  .search-bar__input::placeholder { color: rgba(255,255,255,.38); }

  .search-kbd {
    font-size: .55rem;
    color: rgba(255,255,255,.4);
    border: 1px solid rgba(255,255,255,.18);
    padding: .15rem .35rem;
    border-radius: .2rem;
    letter-spacing: .05em;
    font-family: 'SF Mono', Menlo, monospace;
    flex-shrink: 0;
    transition: opacity .15s;
  }
  .search-bar.active .search-kbd { opacity: 0; pointer-events: none; }

  .search-bar__results {
    list-style: none;
    margin: .35rem 0 0;
    padding: .3rem 0;
    background: rgba(8,6,20,.95);
    border: 1px solid rgba(168,85,247,.3);
    border-radius: .55rem;
    box-shadow: 0 8px 32px rgba(0,0,0,.6), 0 0 24px rgba(168,85,247,.1);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height .2s ease, opacity .15s ease;
    pointer-events: none;
  }
  .search-bar__results.open {
    max-height: 260px;
    opacity: 1;
    pointer-events: all;
    overflow-y: auto;
  }


  .search-proof {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .5rem;
    color: rgba(255,255,255,.4);
    letter-spacing: .12em;
    margin: .7rem 0 0;
    text-align: center;
  }

  .controls-hint {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .38rem;
    color: rgba(255,255,255,.15);
    letter-spacing: .2em;
    z-index: 20;
    white-space: nowrap;
    pointer-events: none;
  }

  @keyframes driftFar  { from { transform: translate(0,0) }   to { transform: translate(60px,40px) } }
  @keyframes driftMid  { from { transform: translate(0,0) }   to { transform: translate(-80px,50px) } }
  @keyframes driftNear { from { transform: translate(0,0) }   to { transform: translate(100px,-60px) } }
</style>

<style is:global>
  /* Search results — dynamically created, must be global */
  .search-result {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .55rem .9rem;
    cursor: pointer;
    transition: background .12s, border-color .12s;
    border-left: 2px solid transparent;
    list-style: none;
  }
  .search-result:hover { background: rgba(255,255,255,.05); }
  .search-result.active {
    background: rgba(255,255,255,.09);
    border-left: 2px solid rgba(168,85,247,.75);
    padding-left: calc(.9rem - 2px);
  }
  .search-result__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .search-result__label {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: .8rem;
    color: rgba(255,255,255,.9);
    flex: 1;
  }

  /* Manually projected node labels — must be global */
  .node-label-wrap {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    pointer-events: none;
    user-select: none;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  .node-label-name {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 11px;
    color: rgba(255,255,255,.9);
    text-shadow: 0 0 12px rgba(0,0,0,1), 0 0 6px rgba(0,0,0,1);
    white-space: nowrap;
  }
  .node-label-name.central {
    font-size: 13px;
    color: #fff;
    text-shadow: 0 0 18px rgba(168,85,247,.7), 0 0 6px rgba(0,0,0,1);
  }
  .node-label-count {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 8px;
    letter-spacing: .12em;
    color: rgba(216,180,254,.65);
    text-shadow: 0 0 8px rgba(0,0,0,1);
    white-space: nowrap;
  }
</style>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
  import * as d3 from "d3";

  // ── node data ──────────────────────────────────────────────────
  const NODE_DEFS = [
    { id: "wiki",        label: "progsu / wiki", desc: "",                                          central: true,  guides: 0,  color: 0xd8b4fe, emissive: 0xa855f7 },
    { id: "foundations", label: "foundations",   desc: "CS theory, math, and first principles",     guides: 8,  route: "/guides/foundations", color: 0xd8b4fe, emissive: 0xa855f7 },
    { id: "career",      label: "career",         desc: "Recruiting, resumes, and offer strategy",  guides: 12, route: "/guides/career",       color: 0xd8b4fe, emissive: 0xa855f7 },
    { id: "networking",  label: "networking",     desc: "Cold outreach, LinkedIn, and warm intros", guides: 6,  route: "/guides/networking",   color: 0xbae6fd, emissive: 0x22d3ee, accent: true },
    { id: "technical",   label: "technical",      desc: "LC, system design, and take-homes",        guides: 9,  route: "/guides/technical",    color: 0xd8b4fe, emissive: 0xa855f7 },
    { id: "experience",  label: "experience",     desc: "Internships, research, and side projects", guides: 5,  route: "/guides/experience",   color: 0xd8b4fe, emissive: 0xa855f7 },
    { id: "resources",   label: "resources",      desc: "Tools, courses, and reading lists",        guides: 7,  route: "/guides/resources",    color: 0xd8b4fe, emissive: 0xa855f7 },
  ] as const;

  type NodeDef   = typeof NODE_DEFS[number];
  type NodeSim   = NodeDef & d3.SimulationNodeDatum & { z: number };
  type LinkDatum = { source: string; target: string };

  const links: LinkDatum[] = [
    { source: "wiki", target: "foundations" },
    { source: "wiki", target: "career" },
    { source: "wiki", target: "networking" },
    { source: "wiki", target: "technical" },
    { source: "wiki", target: "experience" },
    { source: "wiki", target: "resources" },
    { source: "foundations", target: "technical" },
    { source: "career",      target: "networking" },
    { source: "career",      target: "experience" },
  ];

  // ── Three.js setup ─────────────────────────────────────────────
  const root    = document.getElementById("constellation-root")!;
  const canvas  = document.getElementById("graph-canvas") as HTMLCanvasElement;
  const labelEl = document.getElementById("label-layer")!;
  const tip     = document.getElementById("node-tooltip")!;
  const tipName  = tip.querySelector(".tooltip__name")!;
  const tipDesc  = tip.querySelector(".tooltip__desc")!;
  const tipCount = tip.querySelector(".tooltip__count")!;

  let W = root.clientWidth;
  let H = root.clientHeight;

  // Renderer
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setSize(W, H);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setClearColor(0x000000, 0);

  // Scene & camera
  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(55, W / H, 0.1, 2000);
  camera.position.set(0, 0, 420);

  // Ambient: very dim so shadow side is nearly black, not washed
  const ambient = new THREE.AmbientLight(0x080210, 0.6);
  scene.add(ambient);

  // Key: soft white from top-left — lowered intensity so the hotspot is subtle, not blinding
  const keyLight = new THREE.DirectionalLight(0xffffff, 1.8);
  keyLight.position.set(-1.4, 1.4, 2.0);
  scene.add(keyLight);

  // Secondary key: lavender-white, slightly different angle — widens and softens the lit zone
  const key2Light = new THREE.DirectionalLight(0xe8d8ff, 0.7);
  key2Light.position.set(-0.5, 0.6, 1.8);
  scene.add(key2Light);

  // Mid fill: dim purple from the right — creates gradual colour gradient in the penumbra
  // instead of a hard jump from lit → black
  const fillLight = new THREE.DirectionalLight(0x4c1d95, 0.55);
  fillLight.position.set(1.2, 0.2, 0.6);
  scene.add(fillLight);

  // Deep fill: even dimmer violet from below-right — stretches the shadow gradient darker
  const deepFill = new THREE.DirectionalLight(0x1e0a3c, 0.8);
  deepFill.position.set(0.8, -1.0, 0.3);
  scene.add(deepFill);

  // Rim: faint cyan from behind — edge light only, no fill
  const rimLight = new THREE.DirectionalLight(0x22d3ee, 0.18);
  rimLight.position.set(0.3, -1.0, -1.0);
  scene.add(rimLight);

  // OrbitControls — left drag = rotate, middle drag = pan, scroll = zoom
  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping    = true;
  controls.dampingFactor    = 0.08;
  controls.enablePan        = true;
  controls.panSpeed         = 0.8;
  controls.rotateSpeed      = 0.6;
  controls.zoomSpeed        = 1.0;
  controls.minDistance      = 80;
  controls.maxDistance      = 900;
  controls.mouseButtons     = {
    LEFT:   THREE.MOUSE.ROTATE,
    MIDDLE: null as any,
    RIGHT:  THREE.MOUSE.PAN,
  };
  controls.touches = {
    ONE: THREE.TOUCH.ROTATE,
    TWO: THREE.TOUCH.DOLLY_PAN,
  };

  // Double-click resets camera
  canvas.addEventListener("dblclick", () => {
    camera.position.set(0, 0, 420);
    controls.target.set(0, 0, 0);
    controls.update();
  });

  // ── D3 force simulation ────────────────────────────────────────
  // Scale from screen px to scene units
  const SCALE = 0.8;

  const simNodes = NODE_DEFS.map((n, i) => ({
    ...n,
    z: n.id === "wiki" ? 0 : (Math.sin(i * 1.2) * 60),
  })) as NodeSim[];

  const sim = d3.forceSimulation<NodeSim>(simNodes)
    .force("link",    d3.forceLink<NodeSim, LinkDatum>(links).id(d => d.id).distance(200).strength(0.5))
    .force("charge",  d3.forceManyBody().strength(-700))
    .force("center",  d3.forceCenter(0, 0))
    .force("collide", d3.forceCollide<NodeSim>().radius(d => (d.id === "wiki" ? 40 : 25)))
    .alphaDecay(0.025);

  const centerSim = simNodes.find(n => n.id === "wiki")!;
  centerSim.fx = 0;
  centerSim.fy = 0;

  // ── build Three.js objects ─────────────────────────────────────
  const nodeGroup = new THREE.Group();
  scene.add(nodeGroup);

  const edgeGroup = new THREE.Group();
  scene.add(edgeGroup);

  // Shared geometry
  const sphereGeo = new THREE.SphereGeometry(1, 48, 48);

  // Store refs per node
  interface NodeObj {
    sim:       NodeSim;
    mesh:      THREE.Mesh;
    innerGlow: THREE.Mesh;
    midGlow:   THREE.Mesh;
    glow:      THREE.Mesh;
    labelEl:   HTMLDivElement;
    rings?:    THREE.Mesh[];
  }

  const nodeObjs: NodeObj[] = [];
  const meshToNode = new Map<THREE.Mesh, NodeObj>();

  for (const n of simNodes) {
    const isCentral = n.id === "wiki";
    const radius    = isCentral ? 22 : 12;

    // Main sphere — very high shininess for tight white hotspot, dark emissive so shadow goes deep
    // Matches reference: radial-gradient(circle at 35% 30%, white → lavender → purple → #1a0a2e)
    const mat = new THREE.MeshPhongMaterial({
      color:             n.color,
      emissive:          new THREE.Color(n.emissive).multiplyScalar(0.15),
      emissiveIntensity: 1.0,
      shininess:         isCentral ? 180 : 140,
      specular:          new THREE.Color(0xddd0ff),
    });
    const mesh = new THREE.Mesh(sphereGeo, mat);
    mesh.scale.setScalar(radius);
    nodeGroup.add(mesh);

    // Inner bloom — tight halo just over the surface (like box-shadow 0 0 24px)
    const innerGlowMat = new THREE.MeshBasicMaterial({
      color:       n.emissive,
      transparent: true,
      opacity:     isCentral ? 0.35 : 0.22,
      blending:    THREE.AdditiveBlending,
      depthWrite:  false,
    });
    const innerGlow = new THREE.Mesh(sphereGeo, innerGlowMat);
    innerGlow.scale.setScalar(radius * 1.4);
    nodeGroup.add(innerGlow);

    // Mid bloom (like box-shadow 0 0 48-100px)
    const midGlowMat = new THREE.MeshBasicMaterial({
      color:       n.emissive,
      transparent: true,
      opacity:     isCentral ? 0.14 : 0.09,
      blending:    THREE.AdditiveBlending,
      depthWrite:  false,
    });
    const midGlow = new THREE.Mesh(sphereGeo, midGlowMat);
    midGlow.scale.setScalar(radius * (isCentral ? 2.8 : 2.2));
    nodeGroup.add(midGlow);

    const glow = midGlow; // alias — outer bloom removed, midGlow is the widest layer

    // DOM label — projected manually each frame (central node has no label)
    const wrap = document.createElement("div");
    wrap.className = "node-label-wrap";

    if (!isCentral) {
    const namEl = document.createElement("span");
    namEl.className = "node-label-name";
    namEl.textContent = n.label;
    wrap.appendChild(namEl);
    }

    if (!isCentral && "guides" in n) {
      const cntEl = document.createElement("span");
      cntEl.className = "node-label-count";
      cntEl.textContent = `${String(n.guides).padStart(2,"0")} GUIDES`;
      wrap.appendChild(cntEl);
    }
    labelEl.appendChild(wrap);

    // Pulse rings — central node only
    const rings: THREE.Mesh[] = [];
    if (isCentral) {
      const ringGeo = new THREE.RingGeometry(1, 1.06, 64);
      for (let i = 0; i < 3; i++) {
        const ringMat = new THREE.MeshBasicMaterial({
          color:       0xa855f7,
          transparent: true,
          opacity:     0.5,
          blending:    THREE.AdditiveBlending,
          depthWrite:  false,
          side:        THREE.DoubleSide,
        });
        const ring = new THREE.Mesh(ringGeo, ringMat);
        ring.scale.setScalar(radius);
        ring.userData.phaseOffset = i * (1.2 / 3);
        nodeGroup.add(ring);
        rings.push(ring);
      }
    }

    const obj: NodeObj = { sim: n, mesh, innerGlow, midGlow, glow, labelEl: wrap, rings };
    nodeObjs.push(obj);
    meshToNode.set(mesh, obj);
  }

  // Edges — one LineSegments object, updated each tick
  const edgePositions = new Float32Array(links.length * 6); // 2 vertices × 3 floats each
  const edgeGeo = new THREE.BufferGeometry();
  edgeGeo.setAttribute("position", new THREE.BufferAttribute(edgePositions, 3));
  const edgeMat = new THREE.LineBasicMaterial({
    color:       0xa855f7,
    transparent: true,
    opacity:     0.25,
    blending:    THREE.AdditiveBlending,
    depthWrite:  false,
  });
  const edgeMesh = new THREE.LineSegments(edgeGeo, edgeMat);
  edgeGroup.add(edgeMesh);

  // ── raycaster for hover ────────────────────────────────────────
  const raycaster = new THREE.Raycaster();
  const pointer   = new THREE.Vector2();
  let hoveredObj: NodeObj | null = null;
  const meshList  = nodeObjs.map(o => o.mesh);

  canvas.addEventListener("mousemove", (e: MouseEvent) => {
    const rect = canvas.getBoundingClientRect();
    pointer.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    pointer.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;

    raycaster.setFromCamera(pointer, camera);
    const hits = raycaster.intersectObjects(meshList);

    if (hits.length > 0) {
      const obj = meshToNode.get(hits[0].object as THREE.Mesh)!;
      if (obj && !("central" in obj.sim && obj.sim.central)) {
        if (hoveredObj !== obj) {
          if (hoveredObj) unhoverNode(hoveredObj);
          hoverNode(obj);
          hoveredObj = obj;
        }
        const n = obj.sim as any;
        tipName.textContent  = n.label;
        tipDesc.textContent  = n.desc ?? "";
        tipCount.textContent = `${String(n.guides ?? 0).padStart(2,"0")} GUIDES`;
        tip.style.left = `${e.clientX + 16}px`;
        tip.style.top  = `${e.clientY - 14}px`;
        tip.classList.add("visible");
        canvas.style.cursor = "pointer";
      }
    } else {
      if (hoveredObj) { unhoverNode(hoveredObj); hoveredObj = null; }
      tip.classList.remove("visible");
      canvas.style.cursor = "";
    }
  });

  canvas.addEventListener("click", () => {
    if (hoveredObj && !didDrag) {
      const route = (hoveredObj.sim as any).route;
      if (route) window.location.href = route;
    }
  });

  // ── node dragging ──────────────────────────────────────────────
  // Drag a node by holding left-click on it — reuses the same raycaster
  let draggingObj: NodeObj | null = null;
  let didDrag = false;
  const dragPlane  = new THREE.Plane();
  const dragTarget = new THREE.Vector3();
  const projVec    = new THREE.Vector3();

  canvas.addEventListener("mousedown", (e: MouseEvent) => {
    if (e.button !== 0) return;
    const rect = canvas.getBoundingClientRect();
    pointer.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    pointer.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
    raycaster.setFromCamera(pointer, camera);
    const hits = raycaster.intersectObjects(meshList);
    if (hits.length > 0) {
      const obj = meshToNode.get(hits[0].object as THREE.Mesh)!;
      if (obj && !("central" in obj.sim && obj.sim.central)) {
        draggingObj = obj;
        didDrag     = false;
        controls.enabled = false;
        // Drag plane faces camera at the node's current z depth
        dragPlane.setFromNormalAndCoplanarPoint(
          camera.getWorldDirection(new THREE.Vector3()),
          obj.mesh.position
        );
        sim.alphaTarget(0.3).restart();
      }
    }
  });

  window.addEventListener("mousemove", (e: MouseEvent) => {
    if (!draggingObj) return;
    didDrag = true;
    const rect = canvas.getBoundingClientRect();
    pointer.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    pointer.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
    raycaster.setFromCamera(pointer, camera);
    if (raycaster.ray.intersectPlane(dragPlane, dragTarget)) {
      // Map Three.js coords back to D3 space (invert SCALE and Y flip)
      draggingObj.sim.fx = dragTarget.x / SCALE;
      draggingObj.sim.fy = -dragTarget.y / SCALE;
    }
  });

  window.addEventListener("mouseup", (e: MouseEvent) => {
    if (e.button !== 0 || !draggingObj) return;
    draggingObj.sim.fx = null;
    draggingObj.sim.fy = null;
    sim.alphaTarget(0);
    draggingObj = null;
    controls.enabled = true;
  });

  function hoverNode(obj: NodeObj) {
    const isCentral = "central" in obj.sim && obj.sim.central;
    (obj.innerGlow.material as THREE.MeshBasicMaterial).opacity = isCentral ? 0.55 : 0.38;
    (obj.midGlow.material as THREE.MeshBasicMaterial).opacity   = isCentral ? 0.22 : 0.15;
  }

  function unhoverNode(obj: NodeObj) {
    const isCentral = "central" in obj.sim && obj.sim.central;
    (obj.innerGlow.material as THREE.MeshBasicMaterial).opacity = isCentral ? 0.35 : 0.22;
    (obj.midGlow.material as THREE.MeshBasicMaterial).opacity   = isCentral ? 0.14 : 0.09;
  }

  // ── tick: sync Three.js positions with D3 simulation ──────────
  sim.on("tick", () => {
    for (const obj of nodeObjs) {
      const { sim: s, mesh, innerGlow, midGlow, glow } = obj;
      const x = (s.x ?? 0) * SCALE;
      const y = -(s.y ?? 0) * SCALE;
      const z = s.z;
      mesh.position.set(x, y, z);
      innerGlow.position.set(x, y, z);
      midGlow.position.set(x, y, z);
      glow.position.set(x, y, z);
      if (obj.rings) {
        obj.rings.forEach(r => r.position.set(x, y, z));
      }
    }

    // Update edge positions
    const simMap = new Map(simNodes.map(n => [n.id, n]));
    links.forEach((link, i) => {
      const src = simMap.get(typeof link.source === "string" ? link.source : (link.source as any).id)!;
      const tgt = simMap.get(typeof link.target === "string" ? link.target : (link.target as any).id)!;
      const base = i * 6;
      edgePositions[base + 0] = (src.x ?? 0) * SCALE;
      edgePositions[base + 1] = -(src.y ?? 0) * SCALE;
      edgePositions[base + 2] = src.z;
      edgePositions[base + 3] = (tgt.x ?? 0) * SCALE;
      edgePositions[base + 4] = -(tgt.y ?? 0) * SCALE;
      edgePositions[base + 5] = tgt.z;
    });
    edgeGeo.attributes.position.needsUpdate = true;
  });

  // ── mouse parallax for CSS star layers ────────────────────────
  const starsNebula = document.getElementById("layer-nebula")!;
  const starsFar    = document.getElementById("stars-far")!;
  const starsMid    = document.getElementById("stars-mid")!;
  const starsNear   = document.getElementById("stars-near")!;

  let mx = 0, my = 0, rafPending = false;
  document.addEventListener("mousemove", (e: MouseEvent) => {
    mx = (e.clientX / W - 0.5) * 2;
    my = (e.clientY / H - 0.5) * 2;
    if (!rafPending) { rafPending = true; requestAnimationFrame(applyParallax); }
  });
  function applyParallax() {
    rafPending = false;
    starsNebula.style.transform = `translate(${mx * 3}px, ${my * 2}px)`;
    starsFar.style.transform    = `translate(${mx * 6}px, ${my * 4}px)`;
    starsMid.style.transform    = `translate(${mx * 12}px, ${my * 8}px)`;
    starsNear.style.transform   = `translate(${mx * 20}px, ${my * 14}px)`;
  }

  // ── render loop ────────────────────────────────────────────────
  const clock = new THREE.Clock();
  let   animTime = 0;

  function animate() {
    requestAnimationFrame(animate);
    const delta = clock.getDelta();
    animTime += delta;

    controls.update();

    // Pulsate halos on non-central nodes
    for (const obj of nodeObjs) {
      const isCentral = "central" in obj.sim && obj.sim.central;
      if (isCentral) continue;
      // Each node gets a unique phase offset based on its index so they don't all pulse together
      const phaseOffset = simNodes.indexOf(obj.sim) * 0.55;
      const pulse = Math.sin(animTime * 1.1 + phaseOffset) * 0.5 + 0.5; // 0→1
      (obj.innerGlow.material as THREE.MeshBasicMaterial).opacity = 0.12 + pulse * 0.14;
      (obj.midGlow.material   as THREE.MeshBasicMaterial).opacity = 0.04 + pulse * 0.07;
      const baseR = 12;
      obj.innerGlow.scale.setScalar(baseR * (1.4 + pulse * 0.18));
      obj.midGlow.scale.setScalar(baseR   * (2.2 + pulse * 0.3));
    }

    // Animate pulse rings
    for (const obj of nodeObjs) {
      if (!obj.rings) continue;
      const isCentral = "central" in obj.sim && obj.sim.central;
      const radius = isCentral ? 22 : 12;
      obj.rings.forEach(ring => {
        const phase = ((animTime * 0.28 + ring.userData.phaseOffset) % 1);
        const s     = radius + phase * radius * 2.6;
        ring.scale.setScalar(s);
        (ring.material as THREE.MeshBasicMaterial).opacity = (1 - phase) * 0.45;
        // Make rings always face camera
        ring.lookAt(camera.position);
      });
    }

    renderer.render(scene, camera);

    // Project each node's mesh position to screen and position its label div
    for (const obj of nodeObjs) {
      projVec.copy(obj.mesh.position);
      projVec.project(camera);
      // Behind camera — hide
      if (projVec.z > 1) { obj.labelEl.style.visibility = "hidden"; continue; }
      obj.labelEl.style.visibility = "";
      const sx = ( projVec.x * 0.5 + 0.5) * W;
      const sy = (-projVec.y * 0.5 + 0.5) * H;
      // Offset below sphere (radius shrinks with distance, approximate it)
      const isCentral = "central" in obj.sim && obj.sim.central;
      const r = isCentral ? 22 : 12;
      obj.labelEl.style.left = `${sx}px`;
      obj.labelEl.style.top  = `${sy + r + 16}px`;
    }
  }
  animate();

  let idleTimer: ReturnType<typeof setTimeout> | null = null;

  // ── inline search ─────────────────────────────────────────────
  const searchBar     = document.getElementById("search-bar")!;
  const searchInput   = document.getElementById("search-input") as HTMLInputElement;
  const searchResults = document.getElementById("search-results")!;

  const searchableNodes = simNodes.filter(n => n.id !== "wiki");

  function openSearch() {
    if (idleTimer) { clearTimeout(idleTimer); idleTimer = null; }
    root.classList.add("search-open");
    searchBar.classList.add("active");
    searchResults.classList.add("open");
    searchInput.value = "";
    renderResults("");
    searchInput.focus();
  }

  function closeSearch() {
    root.classList.remove("search-open");
    root.classList.remove("graph-focused"); // ESC brings all content back
    searchBar.classList.remove("active");
    searchResults.classList.remove("open");
    searchInput.blur();
  }

  function renderResults(q: string) {
    const matches = q.trim() === ""
      ? searchableNodes
      : searchableNodes.filter(n => n.label.toLowerCase().includes(q.toLowerCase()));

    searchResults.innerHTML = "";
    matches.forEach((n, i) => {
      const li = document.createElement("li");
      li.className = "search-result" + (i === 0 ? " active" : "");
      li.dataset.id = n.id;

      const dot = document.createElement("div");
      dot.className = "search-result__dot";
      const hex = "#" + n.color.toString(16).padStart(6, "0");
      dot.style.background = hex;
      dot.style.boxShadow  = `0 0 6px ${hex}`;

      const label = document.createElement("span");
      label.className = "search-result__label";
      label.textContent = n.label;

      li.appendChild(dot);
      li.appendChild(label);
      li.addEventListener("mousedown", (e) => { e.preventDefault(); zoomToNode(n.id); });
      searchResults.appendChild(li);
    });
  }

  function zoomToNode(id: string) {
    const obj = nodeObjs.find(o => o.sim.id === id);
    if (!obj) return;
    closeSearch();

    const targetPos = obj.mesh.position.clone();
    const startCam  = camera.position.clone();
    const startTgt  = controls.target.clone();
    // Zoom in close to the node — offset along the camera's current forward direction
    const dir = new THREE.Vector3().subVectors(startCam, startTgt).normalize();
    const endCam = targetPos.clone().addScaledVector(dir, 120);

    let t = 0;
    const dur = 55; // frames at 60fps ≈ 0.9s
    function fly() {
      t++;
      const p = 1 - Math.pow(1 - t / dur, 3); // ease-out cubic
      camera.position.lerpVectors(startCam, endCam, p);
      controls.target.lerpVectors(startTgt, targetPos, p);
      controls.update();
      if (t < dur) requestAnimationFrame(fly);
    }
    fly();
  }

  searchBar.addEventListener("click", () => { if (!searchBar.classList.contains("active")) openSearch(); });
  searchInput.addEventListener("input", () => renderResults(searchInput.value));
  searchInput.addEventListener("blur", () => setTimeout(closeSearch, 120));

  searchInput.addEventListener("keydown", (e: KeyboardEvent) => {
    const items = Array.from(searchResults.querySelectorAll<HTMLLIElement>(".search-result"));
    const cur   = items.findIndex(el => el.classList.contains("active"));
    if (e.key === "ArrowDown") {
      e.preventDefault();
      const next = cur === -1 ? 0 : (cur + 1) % items.length;
      items[cur]?.classList.remove("active");
      items[next]?.classList.add("active");
      items[next]?.scrollIntoView({ block: "nearest" });
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      const prev = cur === -1 ? items.length - 1 : (cur - 1 + items.length) % items.length;
      items[cur]?.classList.remove("active");
      items[prev]?.classList.add("active");
      items[prev]?.scrollIntoView({ block: "nearest" });
    } else if (e.key === "Enter") {
      const active = items[cur === -1 ? 0 : cur];
      if (active?.dataset.id) zoomToNode(active.dataset.id);
    } else if (e.key === "Escape") {
      closeSearch();
    }
  });

  // "/" opens search; Escape outside search resets camera to center
  window.addEventListener("keydown", (e: KeyboardEvent) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (e.key === "/" && tag !== "INPUT" && tag !== "TEXTAREA") {
      e.preventDefault();
      openSearch();
    }
    if (e.key === "Escape" && tag !== "INPUT" && tag !== "TEXTAREA") {
      // Animate camera back to default center position
      const startCam = camera.position.clone();
      const startTgt = controls.target.clone();
      const endCam   = new THREE.Vector3(0, 0, 420);
      const endTgt   = new THREE.Vector3(0, 0, 0);
      let t = 0;
      const dur = 50;
      function resetFly() {
        t++;
        const p = 1 - Math.pow(1 - t / dur, 3);
        camera.position.lerpVectors(startCam, endCam, p);
        controls.target.lerpVectors(startTgt, endTgt, p);
        controls.update();
        if (t < dur) requestAnimationFrame(resetFly);
      }
      resetFly();
    }
  });

  // ── focus/unfocus hero copy on graph interaction ──────────────
  function onGraphActivity() {
    root.classList.add("graph-focused");
    if (idleTimer) clearTimeout(idleTimer);
    idleTimer = setTimeout(() => root.classList.remove("graph-focused"), 10_000);
  }

  canvas.addEventListener("mousedown", onGraphActivity);
  canvas.addEventListener("wheel",     onGraphActivity, { passive: true });
  canvas.addEventListener("touchstart", onGraphActivity, { passive: true });

  // ── resize ────────────────────────────────────────────────────
  window.addEventListener("resize", () => {
    W = root.clientWidth;
    H = root.clientHeight;
    camera.aspect = W / H;
    camera.updateProjectionMatrix();
    renderer.setSize(W, H);
  });
</script>
