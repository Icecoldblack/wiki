---
import { SITE_TITLE, NAV_LINKS } from "../consts";
---

<header class="border-b border-gray-800 bg-gray-950/80 backdrop-blur sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-lg font-bold text-white no-underline hover:text-indigo-300">
      {SITE_TITLE}
    </a>
    <ul class="flex gap-6 list-none m-0 p-0">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class="text-sm font-medium no-underline text-gray-300 hover:text-white">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
