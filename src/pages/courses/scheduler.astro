  const panelLive = document.getElementById('panel-live')!;
  const panelEmpty = document.getElementById('panel-empty')!;
  const onboardingHint = document.getElementById('onboarding-hint')!;
  const onboardingDismiss = document.getElementById('onboarding-dismiss')!;

  let current: ScheduleData = store.getActive();
  let scheduled: ResolvedEntry[] = store.resolve(current.courses);

  // ── Skeleton → live swap ──
  panelSkel.classList.add('hidden');
  panelLive.style.display = '';

  // ── Onboarding hint ──
  if (!p.get<boolean>('onboarding.scheduler', false)) {
    onboardingHint.style.display = '';
  }
  onboardingDismiss.addEventListener('click', () => {
    p.set('onboarding.scheduler', true);
    onboardingHint.style.display = 'none';
  });

  function persistSchedule() {
    current.courses = scheduled.map(s => ({ code: s.code, sectionId: s.sectionId }));
    store.updateSchedule(current);
  }

  function fmtT(h: number, m: number) { return fmtTime(h, m); }

  // ── Schedule picker ──
  function renderDropdown() {
    const all = store.getAllSchedules();
    dropdownList.innerHTML = '';
    for (const s of all) {
      const el = document.createElement('div');
      el.className = 'dropdown__item' + (s.id === current.id ? ' active' : '');
      const courseCount = store.resolve(s.courses).length;
      el.innerHTML = `
        <span class="dropdown__item-name">${s.name}</span>
        <span class="dropdown__item-meta">${courseCount} courses</span>
        ${all.length > 1 ? `<button class="dropdown__item-delete" data-delete-id="${s.id}" title="Delete schedule">&times;</button>` : ''}
      `;
      el.addEventListener('click', (ev) => {
        if ((ev.target as HTMLElement).closest('[data-delete-id]')) return;
        switchSchedule(s.id);
        closeDropdown();
      });
      dropdownList.appendChild(el);
    }

    dropdownList.querySelectorAll('[data-delete-id]').forEach(btn => {
      btn.addEventListener('click', (ev) => {
        ev.stopPropagation();
        const id = (btn as HTMLElement).dataset.deleteId!;
        store.deleteSchedule(id);
        if (id === current.id) {
          current = store.getActive();
          scheduled = store.resolve(current.courses);
          refreshUI();
        }
        renderDropdown();
      });
    });
  }

  function switchSchedule(id: string) {
    store.setActive(id);
    current = store.getActive();
    scheduled = store.resolve(current.courses);
    refreshUI();
  }

  function refreshUI() {
    activeSchedName.textContent = current.name;
    semesterSelect.value = current.semester;
    renderBlocks();
    renderPanel();
    renderDayTimeline();
  }

  function openDropdown() {
    dropdown.classList.add('open');
    pickerBtn.setAttribute('aria-expanded', 'true');
    renderDropdown();
  }

  function closeDropdown() {
    dropdown.classList.remove('open');
    pickerBtn.setAttribute('aria-expanded', 'false');
  }

  pickerBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (dropdown.classList.contains('open')) closeDropdown();
    else openDropdown();
  });

  newSchedBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const all = store.getAllSchedules();
    const names = new Set(all.map(s => s.name));
    let name = `${current.name} copy`;
    let i = 2;
    while (names.has(name)) { name = `${current.name} copy ${i++}`; }
    const dup = store.duplicateSchedule(current.id, name);
    switchSchedule(dup.id);
    closeDropdown();
    showToast(`duplicated as "${name}"`);
  });

  activeSchedName.addEventListener('dblclick', () => {
    const input = document.createElement('input');
    input.className = 'topbar__sched-name';
    input.value = current.name;
    input.style.cssText = `
      font-family: var(--font-heading);
      font-style: italic;
      font-size: var(--text-xl);
      color: var(--color-text-primary);
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--glass-border-hi);
      outline: none;
      width: ${Math.max(80, current.name.length * 12)}px;
      padding: var(--space-1) 0;
    `;

    const nameSpan = activeSchedName;
    nameSpan.style.display = 'none';
    nameSpan.parentElement!.insertBefore(input, nameSpan);
    input.focus();
    input.select();

    function commit() {
      const newName = input.value.trim() || current.name;
      current.name = newName;
      persistSchedule();
      nameSpan.textContent = newName;
      nameSpan.style.display = '';
      input.remove();
    }
    input.addEventListener('blur', commit);
    input.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter') { ev.preventDefault(); commit(); }
      if (ev.key === 'Escape') { nameSpan.style.display = ''; input.remove(); }
    });
  });

  semesterSelect.addEventListener('change', () => {
    current.semester = semesterSelect.value;
    persistSchedule();
  });

  // ── Render grid blocks ──
  const GUTTER = 40;
  const HEADER_H = 32;
  const SLOT_H = 20;

  const blockOverlay = document.getElementById('block-overlay')!;

  function renderBlocks() {
    blockOverlay.innerHTML = '';
    const gridW = grid.offsetWidth;
    const colW = (gridW - GUTTER) / DAYS.length;

    interface BlockInfo {
      entry: typeof scheduled[0];
      day: string;
      dayIdx: number;
      startSlot: number;
      endSlot: number;
      color: ReturnType<typeof courseColor>;
      overlapIdx: number;
      overlapTotal: number;
    }

    const blocks: BlockInfo[] = [];
    for (const s of scheduled) {
      const c = courseColor(s.code);
      const startSlot = toSlot(s.section.startH, s.section.startM);
      const endSlot = toSlot(s.section.endH, s.section.endM);
      for (const day of s.section.days) {
        blocks.push({ entry: s, day, dayIdx: DAYS.indexOf(day as any), startSlot, endSlot, color: c, overlapIdx: 0, overlapTotal: 1 });
      }
    }

    // Detect overlaps per day
    for (let d = 0; d < DAYS.length; d++) {
      const dayBlocks = blocks.filter(b => b.dayIdx === d).sort((a, b) => a.startSlot - b.startSlot);
      for (let i = 0; i < dayBlocks.length; i++) {
        const group = [dayBlocks[i]];
        let groupEnd = dayBlocks[i].endSlot;
        for (let j = i + 1; j < dayBlocks.length; j++) {
          if (dayBlocks[j].startSlot < groupEnd) {
            group.push(dayBlocks[j]);
            groupEnd = Math.max(groupEnd, dayBlocks[j].endSlot);
          }
        }
        if (group.length > 1) {
          for (let k = 0; k < group.length; k++) {
            group[k].overlapIdx = k;
            group[k].overlapTotal = group.length;
          }
        }
      }
    }

    for (const b of blocks) {
      const s = b.entry;
      const x = GUTTER + b.dayIdx * colW + (b.overlapIdx * colW / b.overlapTotal);
      const w = colW / b.overlapTotal;
      const y = HEADER_H + b.startSlot * SLOT_H;
      const h = (b.endSlot - b.startSlot) * SLOT_H;

      const el = document.createElement('div');
      el.className = 'sched-block';
      el.dataset.blockCode = s.code;
      el.dataset.blockSection = s.sectionId;
      el.setAttribute('tabindex', '0');
      el.setAttribute('role', 'button');
      el.setAttribute('aria-label', `${s.code} — ${s.course.title}, ${b.day} ${fmtT(s.section.startH, s.section.startM)}–${fmtT(s.section.endH, s.section.endM)}`);
      el.style.left = `${x}px`;
      el.style.top = `${y}px`;
      el.style.width = `${w}px`;
      el.style.height = `${h}px`;
      el.style.background = `linear-gradient(${b.color.bg}, ${b.color.bg}), #0e0e24`;
      el.style.borderColor = b.color.border;
      el.style.setProperty('--block-text', b.color.text);
      el.innerHTML = `<span class="sched-block__code">${s.code}</span><span class="sched-block__room">${s.section.room}</span>`;
      blockOverlay.appendChild(el);
    }
    detectConflicts();
  }

  // ── Render right-panel course list + summary ──
  function renderPanel() {
    panelCourses.innerHTML = '';
    const empty = scheduled.length === 0;
    panelEmpty.style.display = empty ? '' : 'none';
    panelSummary.classList.toggle('hidden', empty);

    for (const s of scheduled) {
      const c = courseColor(s.code);
      const el = document.createElement('div');
      el.className = 'panel-course';
      el.dataset.panelCode = s.code;
      el.innerHTML = `
        <span class="panel-course__dot" style="background:${c.text};box-shadow:0 0 6px ${c.border}"></span>
        <div class="panel-course__info">
          <span class="panel-course__code">${s.code}</span>
          <span class="panel-course__title">${s.course.title}</span>
        </div>
        <span class="panel-course__credits">${s.course.credits} cr</span>
      `;
      panelCourses.appendChild(el);
    }

    if (empty) return;

    const stats = store.computeStats(scheduled);
    const earlyStr = fmtT(Math.floor(stats.earliestMin / 60), stats.earliestMin % 60);
    const lateStr = fmtT(Math.floor(stats.latestMin / 60), stats.latestMin % 60);

    summaryHero.textContent = `${stats.credits} credits`;

    const coreParts: string[] = [];
    coreParts.push(`${stats.contactHours}h/wk`);
    if (stats.daysOff.length) coreParts.push(`${stats.daysOff.join(', ')} off`);

    summaryMeta.innerHTML = `<span>${coreParts.join(' · ')}</span><span class="summary-meta__times"> · ${earlyStr}–${lateStr}</span>`;
  }

  // ── Conflict detection ──
  function detectConflicts() {
    blockOverlay.querySelectorAll('.sched-block').forEach(b => b.classList.remove('conflict'));
    for (let i = 0; i < scheduled.length; i++) {
      for (let j = i + 1; j < scheduled.length; j++) {
        const a = scheduled[i].section, b = scheduled[j].section;
        const aStart = a.startH * 60 + a.startM, aEnd = a.endH * 60 + a.endM;
        const bStart = b.startH * 60 + b.startM, bEnd = b.endH * 60 + b.endM;
        if (aStart >= bEnd || bStart >= aEnd) continue;
        const sharedDays = a.days.filter(d => b.days.includes(d));
        if (sharedDays.length === 0) continue;
        for (const d of sharedDays) {
          blockOverlay.querySelectorAll(`.sched-block[data-block-code="${scheduled[i].code}"]`).forEach(el => {
            const col = DAYS.indexOf(d as any) + 2;
            if ((el as HTMLElement).style.gridColumn.startsWith(String(col))) el.classList.add('conflict');
          });
          blockOverlay.querySelectorAll(`.sched-block[data-block-code="${scheduled[j].code}"]`).forEach(el => {
            const col = DAYS.indexOf(d as any) + 2;
            if ((el as HTMLElement).style.gridColumn.startsWith(String(col))) el.classList.add('conflict');
          });
        }
      }
    }
  }

  // ── Toast system ──
  function showToast(msg: string, undoFn?: () => void, duration = 5000) {
    const el = document.createElement('div');
    el.className = 'toast';
    el.innerHTML = `<span>${msg}</span>`;
    if (undoFn) {
      const btn = document.createElement('button');
      btn.className = 'toast__undo';
      btn.textContent = 'undo';
      btn.addEventListener('click', () => { undoFn(); dismissToast(el); });
      el.appendChild(btn);
    }
    toastContainer.appendChild(el);
    const timer = setTimeout(() => dismissToast(el), duration);
    (el as any)._timer = timer;
  }

  function dismissToast(el: HTMLElement) {
    clearTimeout((el as any)._timer);
    el.classList.add('leaving');
    el.addEventListener('animationend', () => el.remove());
  }

  // ── Add course to schedule ──
  function addToSchedule(course: Course, section: Section) {
    const existing = scheduled.find(s => s.code === course.code);
    if (existing) return;

    const entry: ResolvedEntry = { code: course.code, sectionId: section.id, course, section };
    scheduled.push(entry);
    persistSchedule();

    const conflicts = findConflicts(entry);
    renderBlocks();
    renderPanel();

    if (conflicts.length) {
      showToast(
        `overlaps with ${conflicts[0].code} — added anyway`,
        () => { removeEntry(entry); }
      );
    }

    renderAddPanel();
  }

  function findConflicts(entry: ResolvedEntry): ResolvedEntry[] {
    const results: ResolvedEntry[] = [];
    const a = entry.section;
    const aStart = a.startH * 60 + a.startM, aEnd = a.endH * 60 + a.endM;
    for (const s of scheduled) {
      if (s === entry) continue;
      const b = s.section;
      const bStart = b.startH * 60 + b.startM, bEnd = b.endH * 60 + b.endM;
      if (aStart >= bEnd || bStart >= aEnd) continue;
      if (a.days.some(d => b.days.includes(d))) results.push(s);
    }
    return results;
  }

  // ── Remove course ──
  function removeEntry(entry: ResolvedEntry) {
    const idx = scheduled.indexOf(entry);
    if (idx === -1) return;
    scheduled.splice(idx, 1);
    persistSchedule();
    renderBlocks();
    renderPanel();
    renderAddPanel();
  }

  function removeCourse(code: string) {
    const entry = scheduled.find(s => s.code === code);
    if (!entry) return;
    const snapshot = { ...entry };
    removeEntry(entry);
    showToast(
      `removed ${code}`,
      () => { scheduled.push(snapshot); persistSchedule(); renderBlocks(); renderPanel(); renderAddPanel(); }
    );
  }

  // ── Block keyboard handling (Enter = open, Delete/Backspace = remove) ──
  blockOverlay.addEventListener('keydown', (e) => {
    const block = (e.target as HTMLElement).closest('.sched-block') as HTMLElement | null;
    if (!block) return;
    const code = block.dataset.blockCode!;
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      block.click();
    } else if (e.key === 'Delete' || e.key === 'Backspace') {
      e.preventDefault();
      removeCourse(code);
    }
  });

  // ── Block popover ──
  let popover: HTMLElement | null = null;
  function closePopover() { if (popover) { popover.remove(); popover = null; } }

  document.addEventListener('click', (e) => {
    const block = (e.target as HTMLElement).closest('.sched-block') as HTMLElement | null;
    const inPanel = (e.target as HTMLElement).closest('.add-panel');
    const inDropdown = (e.target as HTMLElement).closest('.topbar__picker');
    if (inPanel) return;

    if (!inDropdown) closeDropdown();

    if (!block) { closePopover(); return; }

    const code = block.dataset.blockCode!;
    const entry = scheduled.find(s => s.code === code);
    if (!entry) return;

    closePopover();

    const rect = block.getBoundingClientRect();
    const el = document.createElement('div');
    el.className = 'block-popover surface-glass surface-glass--strong';
    const sec = entry.section;
    el.innerHTML = `
      <span class="block-popover__code">${entry.code} · ${entry.course.credits} cr</span>
      <span class="block-popover__title">${entry.course.title}</span>
      <span class="block-popover__meta">${sec.professor} · ${sec.days.join('/')} ${fmtT(sec.startH, sec.startM)}–${fmtT(sec.endH, sec.endM)}<br>${sec.room}</span>
      <button class="block-popover__remove" data-remove-code="${code}">remove</button>
    `;

    const left = Math.min(rect.right + 8, window.innerWidth - 240);
    const top = Math.max(rect.top, 8);
    el.style.left = `${left}px`;
    el.style.top = `${top}px`;
    document.body.appendChild(el);
    popover = el;
    el.addEventListener('click', (ev) => {
      const rmBtn = (ev.target as HTMLElement).closest('[data-remove-code]') as HTMLElement | null;
      if (rmBtn) { removeCourse(rmBtn.dataset.removeCode!); closePopover(); }
      ev.stopPropagation();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closePopover();
      closeDropdown();
      closeExportMenu();
      if (addPanel.classList.contains('open')) closeAddPanel();
    }
  });

  // ── Add panel ──
  function openAddPanel() {
    addPanel.classList.add('open');
    addBackdrop.classList.add('open');
    renderAddPanel();
    addSearch.value = '';
    addSearch.focus();
  }

  function closeAddPanel() {
    addPanel.classList.remove('open');
    addBackdrop.classList.remove('open');
  }

  addBtn.addEventListener('click', openAddPanel);
  closeBtn.addEventListener('click', closeAddPanel);
  addBackdrop.addEventListener('click', closeAddPanel);

  function renderAddPanel() {
    const starred = plan.all();
    if (starred.length) {
      savedList.innerHTML = '';
      for (const code of starred) {
        const c = catalog.find(x => x.code === code);
        if (!c) continue;
        renderCourseItem(savedList, c);
      }
    } else {
      savedList.innerHTML = '<p class="add-panel__empty">no starred courses. <a href="/courses" class="add-panel__link">browse courses</a></p>';
    }

    const q = (addSearch?.value ?? '').toLowerCase().trim();
    browseList.innerHTML = '';
    const filtered = q
      ? catalog.filter(c => c.code.toLowerCase().includes(q) || c.title.toLowerCase().includes(q))
      : catalog;
    if (q && filtered.length === 0) {
      browseList.innerHTML = '<p class="add-panel__no-results">no courses match that search.</p>';
    } else {
      for (const c of filtered) {
        renderCourseItem(browseList, c);
      }
    }
  }

  function renderCourseItem(container: HTMLElement, c: Course) {
    const inSched = scheduled.some(s => s.code === c.code);
    const wrapper = document.createElement('div');

    const item = document.createElement('div');
    item.className = 'add-item' + (inSched ? ' in-schedule' : '');
    item.innerHTML = `
      <span class="add-item__code">${c.code}</span>
      <span class="add-item__title">${c.title}</span>
      <svg class="add-item__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
    `;

    const sections = document.createElement('div');
    sections.className = 'add-sections';
    for (const sec of c.sections) {
      const row = document.createElement('div');
      row.className = 'add-section-row';
      row.innerHTML = `<span>${sec.id} · ${sec.professor}</span><span style="display:block;opacity:0.7">${sec.days.join('/')} ${fmtT(sec.startH, sec.startM)}–${fmtT(sec.endH, sec.endM)} · ${sec.seats}/${sec.cap} seats</span>`;
      row.addEventListener('click', (ev) => {
        ev.stopPropagation();
        addToSchedule(c, sec);
        closeAddPanel();
      });
      sections.appendChild(row);
    }

    if (!inSched) {
      item.addEventListener('click', () => {
        item.classList.toggle('expanded');
        sections.classList.toggle('open');
      });
    }

    wrapper.appendChild(item);
    wrapper.appendChild(sections);
    container.appendChild(wrapper);
  }

  addSearch?.addEventListener('input', renderAddPanel);

  // ── Export menu ──
  const exportBtn = document.getElementById('export-btn')!;
  const exportMenu = document.getElementById('export-menu')!;
  const exportIcs = document.getElementById('export-ics')!;
  const exportPrint = document.getElementById('export-print')!;
  const exportShare = document.getElementById('export-share')!;

  function openExportMenu() {
    exportMenu.classList.add('open');
    exportBtn.setAttribute('aria-expanded', 'true');
  }
  function closeExportMenu() {
    exportMenu.classList.remove('open');
    exportBtn.setAttribute('aria-expanded', 'false');
  }

  exportBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (exportMenu.classList.contains('open')) closeExportMenu();
    else openExportMenu();
  });

  exportIcs.addEventListener('click', () => {
    closeExportMenu();
    showToast('calendar export is coming soon');
  });

  exportPrint.addEventListener('click', () => {
    closeExportMenu();
    showToast('print view is coming soon');
  });

  exportShare.addEventListener('click', async () => {
    closeExportMenu();
    if (scheduled.length === 0) {
      showToast('add courses before sharing');
      return;
    }
    const encoded = scheduled
      .map(s => `${s.code.replace(' ', '')}:${s.sectionId}`)
      .join(',');
    const url = `${location.origin}/courses/schedule?s=${encoded}`;
    try {
      await navigator.clipboard.writeText(url);
      showToast('share link copied');
    } catch {
      showToast('could not copy — check browser permissions');
    }
  });

  // Close export menu on outside clicks
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('#export-wrap')) closeExportMenu();
  });

  // ── Mobile day view ──
  const dayPills = document.getElementById('day-pills')!;
  const dayTimeline = document.getElementById('day-timeline')!;
  const dayEmpty = document.getElementById('day-empty')!;
  const dayMap: Record<string, string> = { Mon: 'M', Tue: 'T', Wed: 'W', Thu: 'R', Fri: 'F' };

  let mobileDay = (() => {
    const d = new Date().getDay();
    return DAYS[Math.max(0, Math.min(d - 1, 4))];
  })();

  function selectDayPill(pill: HTMLElement) {
    mobileDay = pill.dataset.day!;
    dayPills.querySelectorAll('.day-pill').forEach(p => {
      p.classList.remove('active');
      p.setAttribute('aria-selected', 'false');
      p.setAttribute('tabindex', '-1');
    });
    pill.classList.add('active');
    pill.setAttribute('aria-selected', 'true');
    pill.setAttribute('tabindex', '0');
    pill.focus();
    renderDayTimeline();
  }

  dayPills.addEventListener('click', (e) => {
    const pill = (e.target as HTMLElement).closest('.day-pill') as HTMLElement | null;
    if (!pill) return;
    selectDayPill(pill);
  });

  dayPills.addEventListener('keydown', (e) => {
    const pills = Array.from(dayPills.querySelectorAll<HTMLElement>('.day-pill'));
    const current = pills.findIndex(p => p.classList.contains('active'));
    if (current === -1) return;
    let next = -1;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { next = (current + 1) % pills.length; }
    else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { next = (current - 1 + pills.length) % pills.length; }
    if (next >= 0) { e.preventDefault(); selectDayPill(pills[next]); }
  });

  function renderDayTimeline() {
    const dayEntries = scheduled
      .filter(s => s.section.days.includes(mobileDay))
      .sort((a, b) => {
        const aMin = a.section.startH * 60 + a.section.startM;
        const bMin = b.section.startH * 60 + b.section.startM;
        return aMin - bMin;
      });

    // Update pill indicators
    const daysWithClasses = new Set(scheduled.flatMap(s => s.section.days));
    dayPills.querySelectorAll('.day-pill').forEach(pill => {
      const day = (pill as HTMLElement).dataset.day!;
      pill.classList.toggle('has-class', daysWithClasses.has(day));
    });

    dayTimeline.innerHTML = '';
    dayEmpty.style.display = dayEntries.length === 0 ? '' : 'none';

    for (const s of dayEntries) {
      const c = subjectColors[s.course.subject] ?? subjectColors.CSC;
      const el = document.createElement('div');
      el.className = 'day-block';
      el.dataset.blockCode = s.code;
      el.setAttribute('tabindex', '0');
      el.setAttribute('role', 'button');
      el.setAttribute('aria-label', `${s.code} — ${s.course.title}, ${fmtT(s.section.startH, s.section.startM)} to ${fmtT(s.section.endH, s.section.endM)}`);
      el.style.cssText = `background:${c.bg};border-color:${c.border};--block-text:${c.text}`;
      el.innerHTML = `
        <span class="day-block__time">${fmtT(s.section.startH, s.section.startM)}–${fmtT(s.section.endH, s.section.endM)}</span>
        <div class="day-block__body">
          <span class="day-block__code">${s.code}</span>
          <span class="day-block__title">${s.course.title}</span>
          <div class="day-block__meta">
            <span>${s.section.professor}</span>
            <span>${s.section.room}</span>
          </div>
        </div>
      `;
      el.addEventListener('keydown', (ev) => {
        if (ev.key === 'Delete' || ev.key === 'Backspace') { ev.preventDefault(); removeCourse(s.code); }
      });
      dayTimeline.appendChild(el);
    }
  }

  // Initial render
  refreshUI();

  window.addEventListener('resize', () => renderBlocks());
</script>
