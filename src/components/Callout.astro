---
interface Props {
  variant?: 'info' | 'warning' | 'tip';
  title?: string;
}

const { variant = 'info', title } = Astro.props;

const icons: Record<string, string> = {
  info: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  warning: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  tip: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
};

const labels: Record<string, string> = {
  info: 'Info',
  warning: 'Warning',
  tip: 'Tip',
};
---

<aside class={`callout callout--${variant} surface-glass`} role="note" aria-label={title || labels[variant]}>
  <div class="callout__icon" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d={icons[variant]} />
    </svg>
  </div>
  <div class="callout__body">
    {title && <p class="callout__title">{title}</p>}
    <div class="callout__content">
      <slot />
    </div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    margin-top: var(--space-6);
  }

  .callout--info {
    background: rgba(168, 85, 247, 0.08);
    border-color: rgba(168, 85, 247, 0.15);
  }
  .callout--info .callout__icon {
    color: var(--color-purple-400);
  }

  .callout--warning {
    background: rgba(245, 158, 11, 0.06);
    border-color: rgba(245, 158, 11, 0.18);
  }
  .callout--warning .callout__icon {
    color: #f59e0b;
  }

  .callout--tip {
    background: rgba(34, 211, 238, 0.06);
    border-color: rgba(34, 211, 238, 0.18);
  }
  .callout--tip .callout__icon {
    color: var(--color-cyan-400);
  }

  .callout__icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .callout__body {
    min-width: 0;
  }

  .callout__title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-wide);
    margin: 0 0 var(--space-2);
  }

  .callout__content {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
  }
  .callout__content :global(p) {
    margin: var(--space-2) 0 0;
  }
  .callout__content :global(p:first-child) {
    margin-top: 0;
  }

  @media (max-width: 480px) {
    .callout {
      padding: var(--space-4) var(--space-4);
      gap: var(--space-3);
    }
  }
</style>
