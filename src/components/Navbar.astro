---
import { NAV_LINKS } from "../consts";

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<a href="#main-content" class="skip-link">Skip to content</a>

<header class="site-header" role="banner">
  <nav class="nav" aria-label="Main">
    <a href="/" class="nav__logo">
      <span class="nav__orb" aria-hidden="true"></span>
      <span class="nav__wordmark">progsu / wiki</span>
    </a>

    <button
      class="nav__toggle surface-glass"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Open menu"
    >
      <svg class="nav__hamburger" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line class="nav__bar nav__bar--top" x1="3" y1="5" x2="17" y2="5" />
        <line class="nav__bar nav__bar--mid" x1="3" y1="10" x2="17" y2="10" />
        <line class="nav__bar nav__bar--bot" x1="3" y1="15" x2="17" y2="15" />
      </svg>
    </button>

    <div id="nav-menu" class="nav__menu surface-glass surface-glass--strong">
      <a href="/" class:list={['nav__link', { 'is-active': isActive('/') }]}>start</a>
      {NAV_LINKS.map((l) => {
        const isExternal = l.href.startsWith('http');
        return (
          <a
            href={l.href}
            class:list={['nav__link', { 'is-active': !isExternal && isActive(l.href) }]}
            {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {l.label.toLowerCase()}
          </a>
        );
      })}
      <kbd class="nav__kbd surface-glass" aria-label="Press / to search">/</kbd>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    padding: var(--space-4) var(--page-gutter);
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--page-width-wide);
    margin: 0 auto;
  }

  /* ── Logo ── */
  .nav__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    padding: var(--space-2) 0;
    min-height: 44px;
  }

  .nav__orb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      var(--color-purple-300) 0%,
      var(--color-purple-500) 50%,
      var(--color-purple-900) 100%
    );
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.6);
    flex-shrink: 0;
  }

  .nav__wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    letter-spacing: var(--tracking-wider);
  }

  /* ── Mobile toggle ── */
  .nav__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    color: var(--color-text-tertiary);
    cursor: pointer;
    padding: 0;
    transition: color var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease);
  }
  .nav__toggle:hover {
    color: var(--color-text-primary);
    border-color: var(--glass-border-hi);
  }

  .nav__bar {
    transition: transform var(--duration-normal) var(--ease),
                opacity var(--duration-fast) var(--ease);
  }
  .nav__bar--top { transform-origin: 10px 5px; }
  .nav__bar--mid { transform-origin: 10px 10px; }
  .nav__bar--bot { transform-origin: 10px 15px; }

  .nav__toggle[aria-expanded="true"] .nav__bar--top {
    transform: translate(0, 5px) rotate(45deg);
  }
  .nav__toggle[aria-expanded="true"] .nav__bar--mid {
    opacity: 0;
  }
  .nav__toggle[aria-expanded="true"] .nav__bar--bot {
    transform: translate(0, -5px) rotate(-45deg);
  }

  /* ── Menu ── */
  .nav__menu {
    display: none;
    position: absolute;
    top: 100%;
    left: var(--page-gutter);
    right: var(--page-gutter);
    flex-direction: column;
    gap: var(--space-1);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
    margin-top: var(--space-2);
  }
  .nav__menu.is-open {
    display: flex;
  }

  /* ── Links ── */
  .nav__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .nav__link:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-surface-hover);
  }
  .nav__link.is-active {
    color: var(--color-text-primary);
  }

  .nav__kbd {
    display: none;
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .nav__toggle {
      display: none;
    }

    .nav__menu {
      display: flex;
      position: static;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      gap: 0;
      background: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      padding: 0;
      margin: 0;
      box-shadow: none;
    }

    .nav__link {
      font-size: var(--text-xs);
      padding: var(--space-2) var(--space-2);
      min-height: auto;
      white-space: nowrap;
    }

    .nav__kbd {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 26px;
      height: 26px;
      border-radius: var(--radius-sm);
      color: var(--color-text-muted);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      margin-left: var(--space-2);
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav__toggle');
  const menu = document.querySelector<HTMLElement>('#nav-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      toggle.setAttribute('aria-label', expanded ? 'Open menu' : 'Close menu');
      menu.classList.toggle('is-open', !expanded);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open menu');
        menu.classList.remove('is-open');
        toggle.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (
        menu.classList.contains('is-open') &&
        !menu.contains(e.target as Node) &&
        !toggle.contains(e.target as Node)
      ) {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open menu');
        menu.classList.remove('is-open');
      }
    });
  }
</script>
