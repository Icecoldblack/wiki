---
// True 3D constellation graph — Three.js spheres, D3 force layout, CSS2D labels
---

<div id="constellation-root">
  <!-- Parallax star layers (CSS, behind WebGL canvas) -->
  <div class="layer-nebula" id="layer-nebula"></div>
  <div class="layer-stars layer-stars--far"  id="stars-far"></div>
  <div class="layer-stars layer-stars--mid"  id="stars-mid"></div>
  <div class="layer-stars layer-stars--near" id="stars-near"></div>
  <div class="vignette"></div>

  <!-- Three.js WebGL canvas -->
  <canvas id="graph-canvas"></canvas>

  <!-- CSS2DRenderer mounts labels here -->
  <div id="label-layer"></div>

  <!-- Hover tooltip -->
  <div id="node-tooltip" class="tooltip surface-glass surface-glass--strong" aria-hidden="true">
    <span class="tooltip__name"></span>
    <span class="tooltip__desc"></span>
    <span class="tooltip__count"></span>
  </div>

  <!-- Eyebrow — floats near top of viewport -->
  <div class="hero-eyebrow-wrap">
    <p class="hero-eyebrow">AN OPEN WIKI &middot; BY PROGSU</p>
  </div>

  <!-- Headline + sub — floats in lower-middle -->
  <div class="hero-headline-wrap">
    <h1 class="hero-headline">the open wiki for<br>breaking into tech.</h1>
    <p class="hero-sub">
      knowledge from people who landed offers in quant, big tech, research, and beyond. signed, dated, free. take what helps.
    </p>
  </div>

  <!-- Search bar — lower third, expands inline on activation -->
  <div class="hero-search-wrap">
    <div id="search-bar" class="search-bar surface-glass">
      <div class="search-icon"><div class="search-handle"></div></div>
      <input id="search-input" class="search-bar__input" type="text" placeholder="search guides &amp; resources" autocomplete="off" spellcheck="false" />
      <span id="search-kbd" class="search-kbd">/</span>
    </div>
    <ul id="search-results" class="search-bar__results surface-glass surface-glass--strong"></ul>
    <p class="search-proof">GROWING WIKI &middot; BY PROGSU &middot; OPEN ON GITHUB</p>
  </div>

  <div class="controls-hint" id="controls-hint-3d">
    drag · rotate &nbsp;|&nbsp; right-drag · pan &nbsp;|&nbsp; scroll · zoom &nbsp;|&nbsp; dbl-click · reset
  </div>
  <div class="controls-hint" id="controls-hint-2d" style="display:none">
    click a node to explore &nbsp;|&nbsp; hover for details
  </div>

  <!-- 2D fallback view -->
  <div id="graph-2d" style="display:none">
    <svg id="graph-2d-svg" width="100%" height="100%"></svg>
  </div>

  <!-- View toggle button -->
  <button id="view-toggle" class="view-toggle surface-glass" aria-label="Switch to 2D view" title="Switch to 2D view">
    <span id="view-toggle-label">2D</span>
  </button>
</div>

<style>
  #constellation-root {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background: #06060f;
  }

  .layer-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 45%, rgba(76,29,149,.35), transparent 70%),
      radial-gradient(ellipse 50% 40% at 20% 75%, rgba(30,27,75,.5),   transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(13,42,90,.4),   transparent 65%),
      linear-gradient(180deg, #02020a 0%, #050516 50%, #02020a 100%);
    will-change: transform;
  }

  .layer-stars { position: absolute; inset: 0; will-change: transform; }

  .layer-stars--far {
    background-image:
      radial-gradient(1px 1px at 12% 23%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 78% 67%, rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 34% 81%, rgba(255,255,255,.45), transparent),
      radial-gradient(1px 1px at 88% 14%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 5%  55%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 65% 30%, rgba(255,255,255,.3), transparent),
      radial-gradient(1px 1px at 25% 8%,  rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 95% 88%, rgba(255,255,255,.4), transparent),
      radial-gradient(1px 1px at 45% 18%, rgba(255,255,255,.3), transparent),
      radial-gradient(1px 1px at 15% 75%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 55% 92%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 38% 45%, rgba(255,255,255,.25), transparent);
    background-size: 280px 280px;
    animation: driftFar 180s linear infinite;
    opacity: .7;
  }

  .layer-stars--mid {
    background-image:
      radial-gradient(1.5px 1.5px at 22% 33%, rgba(255,255,255,.7), transparent),
      radial-gradient(1.5px 1.5px at 68% 57%, rgba(216,180,254,.6), transparent),
      radial-gradient(1.5px 1.5px at 84% 31%, rgba(255,255,255,.65), transparent),
      radial-gradient(1.5px 1.5px at 8%  65%, rgba(255,255,255,.6), transparent),
      radial-gradient(1.5px 1.5px at 92% 78%, rgba(186,230,253,.55), transparent),
      radial-gradient(1.5px 1.5px at 48% 88%, rgba(255,255,255,.5), transparent),
      radial-gradient(1.5px 1.5px at 33% 12%, rgba(255,255,255,.55), transparent),
      radial-gradient(1.5px 1.5px at 72% 8%,  rgba(216,180,254,.5), transparent);
    background-size: 380px 380px;
    animation: driftMid 120s linear infinite;
    opacity: .85;
  }

  .layer-stars--near {
    background-image:
      radial-gradient(2px 2px at 18% 73%, rgba(255,255,255,.95) 0%, rgba(255,255,255,.4) 30%, transparent 60%),
      radial-gradient(2px 2px at 73% 22%, rgba(216,180,254,.85) 0%, rgba(216,180,254,.3) 30%, transparent 60%),
      radial-gradient(2px 2px at 87% 84%, rgba(255,255,255,.9) 0%, rgba(255,255,255,.35) 30%, transparent 60%),
      radial-gradient(2px 2px at 6%  26%, rgba(186,230,253,.8) 0%, rgba(186,230,253,.3) 30%, transparent 60%);
    background-size: 480px 480px;
    animation: driftNear 80s linear infinite;
    opacity: .9;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 95% 80% at 50% 50%, transparent 40%, rgba(0,0,0,.65) 95%);
    pointer-events: none;
    z-index: 2;
  }

  #graph-canvas {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    z-index: 5;
  }

  /* CSS2DRenderer label container */
  #label-layer {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    overflow: hidden;
  }

  /* CSS2DRenderer label container — placeholder, styles moved to is:global below */

  /* Tooltip */
  .tooltip {
    position: fixed;
    padding: .65rem .9rem;
    border-radius: .5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity .15s;
    z-index: 50;
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }
  .tooltip.visible { opacity: 1; }
  .tooltip__name {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: .8rem;
    color: #fff;
  }
  .tooltip__desc {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .58rem;
    color: rgba(216,180,254,.7);
    white-space: normal;
    max-width: 200px;
    line-height: 1.5;
  }
  .tooltip__count {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .52rem;
    color: rgba(255,255,255,.3);
    letter-spacing: .12em;
    margin-top: .1rem;
  }

  /* ── hero copy ─────────────────────────────────────────────── */
  .hero-eyebrow-wrap,
  .hero-headline-wrap,
  .hero-search-wrap {
    transition: opacity .6s ease;
  }

  #constellation-root.graph-focused .hero-eyebrow-wrap,
  #constellation-root.graph-focused .hero-headline-wrap,
  #constellation-root.graph-focused .hero-search-wrap {
    opacity: 0;
    pointer-events: none;
  }

  /* '/' key — only search bar peeks back through */
  #constellation-root.graph-focused.search-open .hero-search-wrap {
    opacity: 1;
    pointer-events: all;
  }

  .hero-eyebrow-wrap {
    position: absolute;
    top: 8%;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 20;
    pointer-events: none;
  }

  .hero-eyebrow {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .55rem;
    color: rgba(216,180,254,.85);
    letter-spacing: .25em;
    margin: 0;
    text-shadow: 0 0 18px rgba(0,0,0,.9);
  }

  .hero-headline-wrap {
    position: absolute;
    bottom: 17%;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 20;
    pointer-events: none;
    padding: 0 1.5rem;
  }

  .hero-headline {
    font-family: Georgia, serif;
    font-style: italic;
    color: #fff;
    font-size: clamp(1.6rem, 3.2vw, 2rem);
    line-height: 1.05;
    letter-spacing: -.01em;
    text-shadow: 0 2px 24px rgba(0,0,0,.85), 0 0 40px rgba(76,29,149,.4);
    max-width: 560px;
    margin: 0 auto .85rem;
  }

  .hero-sub {
    font-family: Georgia, serif;
    font-size: .7rem;
    color: rgba(255,255,255,.7);
    line-height: 1.55;
    max-width: 420px;
    margin: 0 auto;
    text-shadow: 0 1px 8px rgba(0,0,0,.85);
  }

  .hero-search-wrap {
    position: absolute;
    bottom: 5%;
    left: 50%;
    transform: translateX(-50%);
    width: 88%;
    max-width: 480px;
    z-index: 20;
    pointer-events: none;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: .6rem;
    border-radius: .55rem;
    padding: .65rem .9rem;
    width: 100%;
    pointer-events: all;
    cursor: text;
  }

  .search-icon {
    width: 10px;
    height: 10px;
    border: 1.5px solid rgba(216,180,254,.7);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .search-handle {
    position: absolute;
    bottom: -3px;
    right: -3px;
    width: 4px;
    height: 1.5px;
    background: rgba(216,180,254,.7);
    transform: rotate(45deg);
    border-radius: 1px;
  }

  .search-bar__input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .7rem;
    color: rgba(255,255,255,.9);
    caret-color: rgba(168,85,247,.9);
    min-width: 0;
  }
  .search-bar__input::placeholder { color: rgba(255,255,255,.38); }

  .search-kbd {
    font-size: .55rem;
    color: rgba(255,255,255,.4);
    border: 1px solid rgba(255,255,255,.18);
    padding: .15rem .35rem;
    border-radius: .2rem;
    letter-spacing: .05em;
    font-family: 'SF Mono', Menlo, monospace;
    flex-shrink: 0;
    transition: opacity .15s;
  }
  .search-bar.active .search-kbd { opacity: 0; pointer-events: none; }

  .search-bar__results {
    list-style: none;
    margin: .35rem 0 0;
    padding: .3rem 0;
    border-radius: .55rem;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height .2s ease, opacity .15s ease;
    pointer-events: none;
  }
  .search-bar__results.open {
    max-height: 260px;
    opacity: 1;
    pointer-events: all;
    overflow-y: auto;
  }


  .search-proof {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .5rem;
    color: rgba(255,255,255,.4);
    letter-spacing: .12em;
    margin: .7rem 0 0;
    text-align: center;
  }

  .controls-hint {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .38rem;
    color: rgba(255,255,255,.15);
    letter-spacing: .2em;
    z-index: 20;
    white-space: nowrap;
    pointer-events: none;
  }

  @keyframes driftFar  { from { transform: translate(0,0) }   to { transform: translate(60px,40px) } }
  @keyframes driftMid  { from { transform: translate(0,0) }   to { transform: translate(-80px,50px) } }
  @keyframes driftNear { from { transform: translate(0,0) }   to { transform: translate(100px,-60px) } }

  /* ── 2D fallback ──────────────────────────────────────────────── */
  #graph-2d {
    position: absolute;
    inset: 0;
    z-index: 5;
  }

  #graph-2d-svg {
    width: 100%;
    height: 100%;
  }

  /* ── toggle button ────────────────────────────────────────────── */
  .view-toggle {
    position: absolute;
    bottom: 2.8rem;
    right: 1.2rem;
    z-index: 30;
    border-radius: .4rem;
    padding: .35rem .7rem;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: .55rem;
    color: rgba(216,180,254,.85);
    letter-spacing: .15em;
    cursor: pointer;
    transition: background .15s, border-color .15s, color .15s, box-shadow .15s;
    pointer-events: all;
  }
  .view-toggle:hover {
    background: rgba(168,85,247,.18);
    border-color: var(--glass-border-hi);
    color: #fff;
  }
</style>

<style is:global>
  /* Search results — dynamically created, must be global */
  .search-result {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .55rem .9rem;
    cursor: pointer;
    transition: background .12s, border-color .12s;
    border-left: 2px solid transparent;
    list-style: none;
  }
  .search-result:hover { background: rgba(255,255,255,.05); }
  .search-result.active {
    background: rgba(255,255,255,.09);
    border-left: 2px solid rgba(168,85,247,.75);
    padding-left: calc(.9rem - 2px);
  }
  .search-result__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .search-result__label {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: .8rem;
    color: rgba(255,255,255,.9);
    flex: 1;
  }

  /* Manually projected node labels — must be global */
  .node-label-wrap {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    pointer-events: none;
    user-select: none;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  .node-label-name {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 11px;
    color: rgba(255,255,255,.9);
    text-shadow: 0 0 12px rgba(0,0,0,1), 0 0 6px rgba(0,0,0,1);
    white-space: nowrap;
  }
  .node-label-name.central {
    font-size: 13px;
    color: #fff;
    text-shadow: 0 0 18px rgba(168,85,247,.7), 0 0 6px rgba(0,0,0,1);
  }
  .node-label-count {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 8px;
    letter-spacing: .12em;
    color: rgba(216,180,254,.65);
    text-shadow: 0 0 8px rgba(0,0,0,1);
    white-space: nowrap;
  }
</style>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
  import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
  import * as d3 from "d3";
  import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";
  import { EffectComposer } from "three/examples/jsm/postprocessing/EffectComposer.js";
  import { RenderPass } from "three/examples/jsm/postprocessing/RenderPass.js";
  import { UnrealBloomPass } from "three/examples/jsm/postprocessing/UnrealBloomPass.js";
  import { OutputPass } from "three/examples/jsm/postprocessing/OutputPass.js";

  // ── node data ──────────────────────────────────────────────────
  const NODE_DEFS = [
    { id: "wiki",        label: "progsu / wiki", desc: "",                                          central: true,  guides: 0,  color: 0xd8b4fe, emissive: 0xa855f7 },
    { id: "foundations", label: "foundations",   desc: "CS theory, math, and first principles",     guides: 0,  route: "/guides/foundations", color: 0xbae6fd, emissive: 0x22d3ee },
    { id: "career",      label: "career",         desc: "Recruiting, resumes, and offer strategy",  guides: 0,  route: "/guides/career",       color: 0xbbf7d0, emissive: 0x34d399 },
    { id: "networking",  label: "networking",     desc: "Cold outreach, LinkedIn, and warm intros", guides: 0,  route: "/guides/networking",   color: 0xfecdd3, emissive: 0xfb7185 },
    { id: "technical",   label: "technical",      desc: "LC, system design, and take-homes",        guides: 0,  route: "/guides/technical",    color: 0xfde68a, emissive: 0xfbbf24 },
    { id: "misc",        label: "misc",            desc: "Everything else worth knowing",            guides: 0,  route: "/guides/misc",         color: 0xfed7aa, emissive: 0xfb923c },
  ] as const;

  type NodeDef   = typeof NODE_DEFS[number];
  type NodeSim   = NodeDef & d3.SimulationNodeDatum & { z: number };
  type LinkDatum = { source: string; target: string };

  const links: LinkDatum[] = [
    { source: "wiki", target: "foundations" },
    { source: "wiki", target: "career" },
    { source: "wiki", target: "networking" },
    { source: "wiki", target: "technical" },
    { source: "wiki", target: "misc" },
    { source: "foundations", target: "technical" },
    { source: "career",      target: "networking" },
  ];

  // ── Three.js setup ─────────────────────────────────────────────
  const root    = document.getElementById("constellation-root")!;
  const canvas  = document.getElementById("graph-canvas") as HTMLCanvasElement;
  const labelEl = document.getElementById("label-layer")!;
  const tip     = document.getElementById("node-tooltip")!;
  const tipName  = tip.querySelector(".tooltip__name")!;
  const tipDesc  = tip.querySelector(".tooltip__desc")!;
  const tipCount = tip.querySelector(".tooltip__count")!;

  let W = root.clientWidth;
  let H = root.clientHeight;

  // Renderer
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setSize(W, H);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setClearColor(0x000000, 0);
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 0.95;

  // Scene & camera
  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(55, W / H, 0.1, 2000);
  camera.position.set(0, 0, 420);

  const ambient = new THREE.AmbientLight(0x0a0618, 0.3);
  scene.add(ambient);

  const keyLight = new THREE.DirectionalLight(0xfff0e6, 1.0);
  keyLight.position.set(-1.4, 1.4, 2.0);
  scene.add(keyLight);

  const fillLight = new THREE.DirectionalLight(0x4060a0, 0.25);
  fillLight.position.set(1.2, 0.2, 0.6);
  scene.add(fillLight);

  const rimLight = new THREE.DirectionalLight(0x22d3ee, 0.35);
  rimLight.position.set(0.3, -1.0, -1.0);
  scene.add(rimLight);

  // ── Mona model ────────────────────────────────────────────────
  let monaModel: THREE.Object3D | null = null;
  const gltfLoader = new GLTFLoader();
  gltfLoader.load("/mona.glb", (gltf) => {
    monaModel = gltf.scene;
    monaModel.scale.setScalar(60);
    monaModel.position.set(-220, 120, -60);
    monaModel.rotation.y = 0.5;
    // Soften all materials so she reads as background
    monaModel.traverse((child) => {
      if ((child as THREE.Mesh).isMesh) {
        const mesh = child as THREE.Mesh;
        const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
        mats.forEach((m: any) => { if (m) m.opacity !== undefined ? (m.transparent = true, m.opacity = 0.72) : null; });
      }
    });
    // scene.add(monaModel); // hidden — model kept, just not added to scene
  }, undefined, (err) => console.warn("Mona model failed to load:", err));

  // OrbitControls — left drag = rotate, middle drag = pan, scroll = zoom
  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping    = true;
  controls.dampingFactor    = 0.08;
  controls.enablePan        = true;
  controls.panSpeed         = 0.8;
  controls.rotateSpeed      = 0.6;
  controls.zoomSpeed        = 1.0;
  controls.minDistance      = 80;
  controls.maxDistance      = 650;
  controls.mouseButtons     = {
    LEFT:   THREE.MOUSE.ROTATE,
    MIDDLE: null as any,
    RIGHT:  THREE.MOUSE.PAN,
  };
  controls.touches = {
    ONE: THREE.TOUCH.ROTATE,
    TWO: THREE.TOUCH.DOLLY_PAN,
  };

  // Double-click resets camera
  canvas.addEventListener("dblclick", () => {
    camera.position.set(0, 0, 420);
    controls.target.set(0, 0, 0);
    controls.update();
  });

  // ── D3 force simulation ────────────────────────────────────────
  // Scale from screen px to scene units
  const SCALE = 0.8;

  const simNodes = NODE_DEFS.map((n, i) => ({
    ...n,
    z: n.id === "wiki" ? 0 : (Math.sin(i * 1.2) * 60),
  })) as NodeSim[];

  const sim = d3.forceSimulation<NodeSim>(simNodes)
    .force("link",    d3.forceLink<NodeSim, LinkDatum>(links).id(d => d.id).distance(200).strength(0.5))
    .force("charge",  d3.forceManyBody().strength(-700))
    .force("center",  d3.forceCenter(0, 0))
    .force("collide", d3.forceCollide<NodeSim>().radius(d => (d.id === "wiki" ? 40 : 25)))
    .alphaDecay(0.025);

  const centerSim = simNodes.find(n => n.id === "wiki")!;
  centerSim.fx = 0;
  centerSim.fy = 0;

  // ── environment map & procedural textures ──────────────────────
  const pmremGen = new THREE.PMREMGenerator(renderer);
  const envMap = pmremGen.fromScene(new RoomEnvironment(), 0.04).texture;
  scene.environment = envMap;
  pmremGen.dispose();

  const supportsTransmission = renderer.capabilities.isWebGL2;

  function generateNoiseNormalMap(size = 128): THREE.DataTexture {
    const heights = new Float32Array(size * size);
    for (let y = 0; y < size; y++) {
      for (let x = 0; x < size; x++) {
        const u = x / size, v = y / size;
        heights[y * size + x] =
          Math.sin(u * 6.28 * 3 + v * 2.1) * 0.3 +
          Math.cos(u * 1.7 + v * 6.28 * 2) * 0.3 +
          Math.sin((u + v) * 6.28 * 5) * 0.15 +
          Math.sin(u * 6.28 * 7 - v * 3.3) * 0.1 +
          Math.sin(u * 43.7) * Math.sin(v * 37.3) * 0.15;
      }
    }
    const data = new Uint8Array(size * size * 4);
    for (let y = 0; y < size; y++) {
      for (let x = 0; x < size; x++) {
        const i = y * size + x;
        const dx = heights[y * size + (x + 1) % size] - heights[y * size + (x - 1 + size) % size];
        const dy = heights[((y + 1) % size) * size + x] - heights[((y - 1 + size) % size) * size + x];
        const len = Math.sqrt(dx * dx + dy * dy + 1);
        data[i * 4]     = Math.round((-dx / len * 0.5 + 0.5) * 255);
        data[i * 4 + 1] = Math.round((-dy / len * 0.5 + 0.5) * 255);
        data[i * 4 + 2] = Math.round((1.0 / len * 0.5 + 0.5) * 255);
        data[i * 4 + 3] = 255;
      }
    }
    const tex = new THREE.DataTexture(data, size, size);
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    tex.needsUpdate = true;
    return tex;
  }
  const normalMap = generateNoiseNormalMap();

  // ── nebula cloud textures (fbm noise × radial falloff) ──────────
  function hash(x: number, y: number): number {
    let n = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
    return n - Math.floor(n);
  }
  function smoothNoise(x: number, y: number): number {
    const ix = Math.floor(x), iy = Math.floor(y);
    const fx = x - ix, fy = y - iy;
    const ux = fx * fx * (3 - 2 * fx), uy = fy * fy * (3 - 2 * fy);
    const a = hash(ix, iy), b = hash(ix + 1, iy);
    const c = hash(ix, iy + 1), d = hash(ix + 1, iy + 1);
    return a + (b - a) * ux + (c - a) * uy + (a - b - c + d) * ux * uy;
  }
  function fbm(x: number, y: number, octaves = 4): number {
    let v = 0, amp = 0.5, freq = 1;
    for (let i = 0; i < octaves; i++) {
      v += amp * smoothNoise(x * freq, y * freq);
      amp *= 0.5; freq *= 2.0;
    }
    return v;
  }

  function generateCloudTexture(size = 192, seed = 0): THREE.CanvasTexture {
    const c = document.createElement("canvas");
    c.width = size; c.height = size;
    const ctx = c.getContext("2d")!;
    const img = ctx.createImageData(size, size);
    const half = size / 2;
    for (let y = 0; y < size; y++) {
      for (let x = 0; x < size; x++) {
        const u = (x - half) / half;
        const v = (y - half) / half;
        const dist = Math.sqrt(u * u + v * v);
        const falloff = Math.max(0, 1 - dist);
        const soft = falloff * falloff * (3 - 2 * falloff);
        const n = fbm(u * 3 + seed * 13.7, v * 3 + seed * 7.3, 4);
        const wisp = Math.max(0, n - 0.25) * 2.0;
        const alpha = Math.min(1, wisp * soft * 1.6);
        const i = (y * size + x) * 4;
        img.data[i] = 255; img.data[i + 1] = 255; img.data[i + 2] = 255;
        img.data[i + 3] = Math.round(alpha * 255);
      }
    }
    ctx.putImageData(img, 0, 0);
    const tex = new THREE.CanvasTexture(c);
    tex.needsUpdate = true;
    return tex;
  }
  const cloudPool: THREE.CanvasTexture[] = [];
  for (let i = 0; i < 5; i++) cloudPool.push(generateCloudTexture(192, i));

  // ── build Three.js objects ─────────────────────────────────────
  const nodeGroup = new THREE.Group();
  scene.add(nodeGroup);

  const edgeGroup = new THREE.Group();
  scene.add(edgeGroup);

  // Shared geometry
  const sphereGeo = new THREE.SphereGeometry(1, 48, 48);

  interface CloudLayer {
    sprite:    THREE.Sprite;
    baseScale: number;
    baseOp:    number;
    rotSpeed:  number;
  }

  interface NodeObj {
    sim:       NodeSim;
    mesh:      THREE.Mesh;
    clouds:    CloudLayer[];
    labelEl:   HTMLDivElement;
  }

  const nodeObjs: NodeObj[] = [];
  const meshToNode = new Map<THREE.Mesh, NodeObj>();

  for (const n of simNodes) {
    const isCentral = n.id === "wiki";
    const radius    = isCentral ? 22 : 12;

    const mat = new THREE.MeshPhysicalMaterial({
      color:              new THREE.Color(n.color).multiplyScalar(0.45),
      emissive:           new THREE.Color(n.emissive).multiplyScalar(0.4),
      emissiveIntensity:  isCentral ? 0.55 : 0.45,
      roughness:          1.0,
      metalness:          0.0,
    });
    const mesh = new THREE.Mesh(sphereGeo, mat);
    mesh.scale.setScalar(radius);
    mesh.userData.hoverT = 0;
    mesh.userData.hoverTarget = 0;
    nodeGroup.add(mesh);

    // Central node keeps neighbor-blended outer tint; satellites stay pure color
    let outerTint: THREE.Color;
    if (isCentral) {
      const neighborColors: THREE.Color[] = [];
      for (const link of links) {
        const srcId = typeof link.source === "string" ? link.source : (link.source as any).id;
        const tgtId = typeof link.target === "string" ? link.target : (link.target as any).id;
        if (srcId === n.id) {
          const nb = simNodes.find(s => s.id === tgtId);
          if (nb) neighborColors.push(new THREE.Color(nb.emissive));
        } else if (tgtId === n.id) {
          const nb = simNodes.find(s => s.id === srcId);
          if (nb) neighborColors.push(new THREE.Color(nb.emissive));
        }
      }
      outerTint = new THREE.Color(n.emissive);
      if (neighborColors.length > 0) {
        const avg = new THREE.Color(0, 0, 0);
        for (const c of neighborColors) avg.add(c);
        avg.multiplyScalar(1 / neighborColors.length);
        outerTint.lerp(avg, 0.35);
      }
    } else {
      outerTint = new THREE.Color(n.emissive);
    }

    const layerDefs = isCentral ? [
      { scale: 2.8, op: 0.22, speed:  0.06 },
      { scale: 4.2, op: 0.14, speed: -0.04 },
      { scale: 6.0, op: 0.08, speed:  0.025 },
    ] : [
      { scale: 3.0, op: 0.28, speed:  0.06 },
      { scale: 5.0, op: 0.18, speed: -0.04 },
      { scale: 7.5, op: 0.10, speed:  0.025 },
    ];
    const clouds: CloudLayer[] = [];
    const nodeIdx = simNodes.indexOf(n);
    for (let li = 0; li < layerDefs.length; li++) {
      const def = layerDefs[li];
      const tex = cloudPool[(nodeIdx * 3 + li) % cloudPool.length];
      const tint = li === 2 ? outerTint : new THREE.Color(n.emissive);
      const cMat = new THREE.SpriteMaterial({
        map:         tex,
        color:       tint,
        transparent: true,
        opacity:     def.op,
        blending:    THREE.AdditiveBlending,
        depthWrite:  false,
        rotation:    (nodeIdx + li) * 1.3,
      });
      const spr = new THREE.Sprite(cMat);
      spr.scale.setScalar(radius * def.scale);
      nodeGroup.add(spr);
      clouds.push({ sprite: spr, baseScale: radius * def.scale, baseOp: def.op, rotSpeed: def.speed * (li % 2 === 0 ? 1 : -1) });
    }

    // DOM label — projected manually each frame (central node has no label)
    const wrap = document.createElement("div");
    wrap.className = "node-label-wrap";

    if (!isCentral) {
    const namEl = document.createElement("span");
    namEl.className = "node-label-name";
    namEl.textContent = n.label;
    wrap.appendChild(namEl);
    }

    labelEl.appendChild(wrap);

    const obj: NodeObj = { sim: n, mesh, clouds, labelEl: wrap };
    nodeObjs.push(obj);
    meshToNode.set(mesh, obj);
  }

  // Edges — one LineSegments object, updated each tick
  const edgePositions = new Float32Array(links.length * 6); // 2 vertices × 3 floats each
  const edgeGeo = new THREE.BufferGeometry();
  edgeGeo.setAttribute("position", new THREE.BufferAttribute(edgePositions, 3));
  const edgeMat = new THREE.LineBasicMaterial({
    color:       0xa855f7,
    transparent: true,
    opacity:     0.08,
    blending:    THREE.AdditiveBlending,
    depthWrite:  false,
  });
  const edgeMesh = new THREE.LineSegments(edgeGeo, edgeMat);
  edgeGroup.add(edgeMesh);

  // ── diffuse background cloud ───────────────────────────────────
  const bgCloudMat = new THREE.SpriteMaterial({
    map:         cloudPool[0],
    color:       0xa855f7,
    transparent: true,
    opacity:     0.06,
    blending:    THREE.AdditiveBlending,
    depthWrite:  false,
  });
  const bgCloud = new THREE.Sprite(bgCloudMat);
  bgCloud.scale.setScalar(500);
  bgCloud.position.set(0, 0, -20);
  scene.add(bgCloud);

  // ── bloom post-processing ──────────────────────────────────────
  const composer = new EffectComposer(renderer);
  composer.addPass(new RenderPass(scene, camera));
  const bloomPass = new UnrealBloomPass(
    new THREE.Vector2(W, H),
    0.35,
    0.6,
    0.55
  );
  composer.addPass(bloomPass);
  composer.addPass(new OutputPass());

  // ── raycaster for hover ────────────────────────────────────────
  const raycaster = new THREE.Raycaster();
  const pointer   = new THREE.Vector2();
  let hoveredObj: NodeObj | null = null;
  const meshList  = nodeObjs.map(o => o.mesh);

  canvas.addEventListener("mousemove", (e: MouseEvent) => {
    const rect = canvas.getBoundingClientRect();
    pointer.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    pointer.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;

    raycaster.setFromCamera(pointer, camera);
    const hits = raycaster.intersectObjects(meshList);

    if (hits.length > 0) {
      const obj = meshToNode.get(hits[0].object as THREE.Mesh)!;
      if (obj && !("central" in obj.sim && obj.sim.central)) {
        if (hoveredObj !== obj) {
          if (hoveredObj) unhoverNode(hoveredObj);
          hoverNode(obj);
          hoveredObj = obj;
        }
        const n = obj.sim as any;
        tipName.textContent  = n.label;
        tipDesc.textContent  = n.desc ?? "";
        tipCount.textContent = "";
        tip.style.left = `${e.clientX + 16}px`;
        tip.style.top  = `${e.clientY - 14}px`;
        tip.classList.add("visible");
        canvas.style.cursor = "pointer";
      }
    } else {
      if (hoveredObj) { unhoverNode(hoveredObj); hoveredObj = null; }
      tip.classList.remove("visible");
      canvas.style.cursor = "";
    }
  });

  canvas.addEventListener("click", () => {
    if (hoveredObj && !didDrag) {
      const route = (hoveredObj.sim as any).route;
      if (route) window.location.href = route;
    }
  });

  // ── node dragging ──────────────────────────────────────────────
  // Drag a node by holding left-click on it — reuses the same raycaster
  let draggingObj: NodeObj | null = null;
  let didDrag = false;
  const dragPlane  = new THREE.Plane();
  const dragTarget = new THREE.Vector3();
  const projVec    = new THREE.Vector3();

  canvas.addEventListener("mousedown", (e: MouseEvent) => {
    if (e.button !== 0) return;
    const rect = canvas.getBoundingClientRect();
    pointer.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    pointer.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
    raycaster.setFromCamera(pointer, camera);
    const hits = raycaster.intersectObjects(meshList);
    if (hits.length > 0) {
      const obj = meshToNode.get(hits[0].object as THREE.Mesh)!;
      if (obj && !("central" in obj.sim && obj.sim.central)) {
        draggingObj = obj;
        didDrag     = false;
        controls.enabled = false;
        // Drag plane faces camera at the node's current z depth
        dragPlane.setFromNormalAndCoplanarPoint(
          camera.getWorldDirection(new THREE.Vector3()),
          obj.mesh.position
        );
        sim.alphaTarget(0.3).restart();
      }
    }
  });

  window.addEventListener("mousemove", (e: MouseEvent) => {
    if (!draggingObj) return;
    didDrag = true;
    const rect = canvas.getBoundingClientRect();
    pointer.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    pointer.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
    raycaster.setFromCamera(pointer, camera);
    if (raycaster.ray.intersectPlane(dragPlane, dragTarget)) {
      // Map Three.js coords back to D3 space (invert SCALE and Y flip)
      draggingObj.sim.fx = dragTarget.x / SCALE;
      draggingObj.sim.fy = -dragTarget.y / SCALE;
    }
  });

  window.addEventListener("mouseup", (e: MouseEvent) => {
    if (e.button !== 0 || !draggingObj) return;
    draggingObj.sim.fx = null;
    draggingObj.sim.fy = null;
    sim.alphaTarget(0);
    draggingObj = null;
    controls.enabled = true;
  });

  function hoverNode(obj: NodeObj) {
    obj.mesh.userData.hoverTarget = 1;
  }

  function unhoverNode(obj: NodeObj) {
    obj.mesh.userData.hoverTarget = 0;
  }

  // ── tick: sync Three.js positions with D3 simulation ──────────
  sim.on("tick", () => {
    for (const obj of nodeObjs) {
      const { sim: s, mesh, clouds } = obj;
      const x = (s.x ?? 0) * SCALE;
      const y = -(s.y ?? 0) * SCALE;
      const z = s.z;
      mesh.position.set(x, y, z);
      for (const cl of clouds) cl.sprite.position.set(x, y, z);
    }

    // Update edge positions
    const simMap = new Map(simNodes.map(n => [n.id, n]));
    links.forEach((link, i) => {
      const src = simMap.get(typeof link.source === "string" ? link.source : (link.source as any).id)!;
      const tgt = simMap.get(typeof link.target === "string" ? link.target : (link.target as any).id)!;
      const base = i * 6;
      edgePositions[base + 0] = (src.x ?? 0) * SCALE;
      edgePositions[base + 1] = -(src.y ?? 0) * SCALE;
      edgePositions[base + 2] = src.z;
      edgePositions[base + 3] = (tgt.x ?? 0) * SCALE;
      edgePositions[base + 4] = -(tgt.y ?? 0) * SCALE;
      edgePositions[base + 5] = tgt.z;
    });
    edgeGeo.attributes.position.needsUpdate = true;

  });

  // ── mouse parallax for CSS star layers ────────────────────────
  const starsNebula = document.getElementById("layer-nebula")!;
  const starsFar    = document.getElementById("stars-far")!;
  const starsMid    = document.getElementById("stars-mid")!;
  const starsNear   = document.getElementById("stars-near")!;

  let mx = 0, my = 0, rafPending = false;
  document.addEventListener("mousemove", (e: MouseEvent) => {
    mx = (e.clientX / W - 0.5) * 2;
    my = (e.clientY / H - 0.5) * 2;
    if (!rafPending) { rafPending = true; requestAnimationFrame(applyParallax); }
  });
  function applyParallax() {
    rafPending = false;
    starsNebula.style.transform = `translate(${mx * 3}px, ${my * 2}px)`;
    starsFar.style.transform    = `translate(${mx * 6}px, ${my * 4}px)`;
    starsMid.style.transform    = `translate(${mx * 12}px, ${my * 8}px)`;
    starsNear.style.transform   = `translate(${mx * 20}px, ${my * 14}px)`;
  }

  // ── render loop ────────────────────────────────────────────────
  const clock = new THREE.Clock();
  let   animTime = 0;

  function animate() {
    requestAnimationFrame(animate);
    const delta = clock.getDelta();
    animTime += delta;

    controls.update();

    // Slow idle sway on Mona
    if (monaModel) {
      monaModel.position.y = 120 + Math.sin(animTime * 0.8) * 6;
      monaModel.rotation.y = 0.5 + Math.sin(animTime * 0.25) * 0.08;
    }

    // Clamp pan so the graph can't drift off-screen
    const PAN_LIMIT = 200;
    controls.target.x = Math.max(-PAN_LIMIT, Math.min(PAN_LIMIT, controls.target.x));
    controls.target.y = Math.max(-PAN_LIMIT, Math.min(PAN_LIMIT, controls.target.y));
    controls.target.z = Math.max(-PAN_LIMIT, Math.min(PAN_LIMIT, controls.target.z));

    // Shared nebula breathe phase — one organism
    const breathe = Math.sin(animTime * 0.4) * 0.04;

    // Node cloud drift and hover
    for (const obj of nodeObjs) {
      const isCentral = "central" in obj.sim && obj.sim.central;
      const ht = obj.mesh.userData.hoverT += (obj.mesh.userData.hoverTarget - obj.mesh.userData.hoverT) * 0.12;
      const nodeIdx = nodeObjs.indexOf(obj);

      for (let ci = 0; ci < obj.clouds.length; ci++) {
        const cl = obj.clouds[ci];
        const mat = cl.sprite.material as THREE.SpriteMaterial;
        const phase = animTime * cl.rotSpeed + nodeIdx * 0.4 + ci * 0.9;
        mat.rotation = phase;
        mat.opacity = Math.max(0, cl.baseOp + breathe) + ht * cl.baseOp * 0.8;
        cl.sprite.scale.setScalar(cl.baseScale * (1 + ht * 0.25));
      }

      const meshMat = obj.mesh.material as THREE.MeshPhysicalMaterial;
      meshMat.emissiveIntensity = (isCentral ? 0.55 : 0.45) + ht * 0.45;
    }

    // Background cloud slow drift
    (bgCloud.material as THREE.SpriteMaterial).rotation = animTime * 0.008;
    (bgCloud.material as THREE.SpriteMaterial).opacity = Math.max(0, 0.06 + breathe * 0.3);

    composer.render();

    // Project each node's mesh position to screen and position its label div
    for (const obj of nodeObjs) {
      projVec.copy(obj.mesh.position);
      projVec.project(camera);
      // Behind camera — hide
      if (projVec.z > 1) { obj.labelEl.style.visibility = "hidden"; continue; }
      obj.labelEl.style.visibility = "";
      const sx = ( projVec.x * 0.5 + 0.5) * W;
      const sy = (-projVec.y * 0.5 + 0.5) * H;
      // Offset below sphere (radius shrinks with distance, approximate it)
      const isCentral = "central" in obj.sim && obj.sim.central;
      const r = isCentral ? 22 : 12;
      obj.labelEl.style.left = `${sx}px`;
      obj.labelEl.style.top  = `${sy + r + 16}px`;
    }
  }
  animate();

  let idleTimer: ReturnType<typeof setTimeout> | null = null;

  // ── inline search ─────────────────────────────────────────────
  const searchBar     = document.getElementById("search-bar")!;
  const searchInput   = document.getElementById("search-input") as HTMLInputElement;
  const searchResults = document.getElementById("search-results")!;

  const searchableNodes = simNodes.filter(n => n.id !== "wiki");

  function openSearch() {
    if (idleTimer) { clearTimeout(idleTimer); idleTimer = null; }
    root.classList.add("search-open");
    searchBar.classList.add("active");
    searchResults.classList.add("open");
    searchInput.value = "";
    renderResults("");
    searchInput.focus();
  }

  function closeSearch() {
    root.classList.remove("search-open");
    root.classList.remove("graph-focused"); // ESC brings all content back
    searchBar.classList.remove("active");
    searchResults.classList.remove("open");
    searchInput.blur();
  }

  function renderResults(q: string) {
    const matches = q.trim() === ""
      ? searchableNodes
      : searchableNodes.filter(n => n.label.toLowerCase().includes(q.toLowerCase()));

    searchResults.innerHTML = "";
    matches.forEach((n, i) => {
      const li = document.createElement("li");
      li.className = "search-result" + (i === 0 ? " active" : "");
      li.dataset.id = n.id;

      const dot = document.createElement("div");
      dot.className = "search-result__dot";
      const hex = "#" + n.color.toString(16).padStart(6, "0");
      dot.style.background = hex;
      dot.style.boxShadow  = `0 0 6px ${hex}`;

      const label = document.createElement("span");
      label.className = "search-result__label";
      label.textContent = n.label;

      li.appendChild(dot);
      li.appendChild(label);
      li.addEventListener("mousedown", (e) => {
        e.preventDefault();
        if (is2D) {
          const route = (n as any).route;
          if (route) window.location.href = route;
        } else {
          zoomToNode(n.id);
        }
      });
      searchResults.appendChild(li);
    });
  }

  function zoomToNode(id: string) {
    const obj = nodeObjs.find(o => o.sim.id === id);
    if (!obj) return;
    closeSearch();

    const targetPos = obj.mesh.position.clone();
    const startCam  = camera.position.clone();
    const startTgt  = controls.target.clone();
    // Zoom in close to the node — offset along the camera's current forward direction
    const dir = new THREE.Vector3().subVectors(startCam, startTgt).normalize();
    const endCam = targetPos.clone().addScaledVector(dir, 120);

    let t = 0;
    const dur = 55; // frames at 60fps ≈ 0.9s
    function fly() {
      t++;
      const p = 1 - Math.pow(1 - t / dur, 3); // ease-out cubic
      camera.position.lerpVectors(startCam, endCam, p);
      controls.target.lerpVectors(startTgt, targetPos, p);
      controls.update();
      if (t < dur) requestAnimationFrame(fly);
    }
    fly();
  }

  searchBar.addEventListener("click", () => { if (!searchBar.classList.contains("active")) openSearch(); });
  searchInput.addEventListener("input", () => renderResults(searchInput.value));
  searchInput.addEventListener("blur", () => setTimeout(closeSearch, 120));

  searchInput.addEventListener("keydown", (e: KeyboardEvent) => {
    const items = Array.from(searchResults.querySelectorAll<HTMLLIElement>(".search-result"));
    const cur   = items.findIndex(el => el.classList.contains("active"));
    if (e.key === "ArrowDown") {
      e.preventDefault();
      const next = cur === -1 ? 0 : (cur + 1) % items.length;
      items[cur]?.classList.remove("active");
      items[next]?.classList.add("active");
      items[next]?.scrollIntoView({ block: "nearest" });
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      const prev = cur === -1 ? items.length - 1 : (cur - 1 + items.length) % items.length;
      items[cur]?.classList.remove("active");
      items[prev]?.classList.add("active");
      items[prev]?.scrollIntoView({ block: "nearest" });
    } else if (e.key === "Enter") {
      const active = items[cur === -1 ? 0 : cur];
      if (active?.dataset.id) {
        if (is2D) {
          const node = simNodes.find(n => n.id === active.dataset.id);
          const route = (node as any)?.route;
          if (route) window.location.href = route;
        } else {
          zoomToNode(active.dataset.id);
        }
      }
    } else if (e.key === "Escape") {
      closeSearch();
    }
  });

  // "/" opens search; Escape outside search resets camera to center
  window.addEventListener("keydown", (e: KeyboardEvent) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (e.key === "/" && tag !== "INPUT" && tag !== "TEXTAREA") {
      e.preventDefault();
      openSearch();
    }
    if (e.key === "Escape" && tag !== "INPUT" && tag !== "TEXTAREA") {
      // Animate camera back to default center position
      const startCam = camera.position.clone();
      const startTgt = controls.target.clone();
      const endCam   = new THREE.Vector3(0, 0, 420);
      const endTgt   = new THREE.Vector3(0, 0, 0);
      let t = 0;
      const dur = 50;
      function resetFly() {
        t++;
        const p = 1 - Math.pow(1 - t / dur, 3);
        camera.position.lerpVectors(startCam, endCam, p);
        controls.target.lerpVectors(startTgt, endTgt, p);
        controls.update();
        if (t < dur) requestAnimationFrame(resetFly);
      }
      resetFly();
    }
  });

  // ── focus/unfocus hero copy on graph interaction ──────────────
  function onGraphActivity() {
    if (is2D) return;
    root.classList.add("graph-focused");
    if (idleTimer) clearTimeout(idleTimer);
    idleTimer = setTimeout(() => root.classList.remove("graph-focused"), 10_000);
  }

  canvas.addEventListener("mousedown", onGraphActivity);
  canvas.addEventListener("wheel",     onGraphActivity, { passive: true });
  canvas.addEventListener("touchstart", onGraphActivity, { passive: true });

  // ── resize ────────────────────────────────────────────────────
  window.addEventListener("resize", () => {
    W = root.clientWidth;
    H = root.clientHeight;
    camera.aspect = W / H;
    camera.updateProjectionMatrix();
    renderer.setSize(W, H);
    composer.setSize(W, H);
    if (is2D) draw2D();
  });

  // ── 2D fallback view ──────────────────────────────────────────
  const graph2dEl    = document.getElementById("graph-2d")!;
  const svg2d        = document.getElementById("graph-2d-svg") as unknown as SVGSVGElement;
  const hint3d       = document.getElementById("controls-hint-3d")!;
  const hint2d       = document.getElementById("controls-hint-2d")!;
  const toggleBtn    = document.getElementById("view-toggle")!;
  const toggleLabel  = document.getElementById("view-toggle-label")!;
  let   is2D         = false;

  const NS = "http://www.w3.org/2000/svg";

  // Radial layout: center node + 5 evenly spread around it
  function get2DPositions(w: number, h: number) {
    const cx = w / 2, cy = h * 0.40;
    const r  = Math.min(w, h) * 0.22;
    const positions: Record<string, { x: number; y: number }> = { wiki: { x: cx, y: cy } };
    const satellites = simNodes.filter(n => n.id !== "wiki");
    satellites.forEach((n, i) => {
      const angle = (i / satellites.length) * Math.PI * 2 - Math.PI / 2;
      positions[n.id] = { x: cx + Math.cos(angle) * r, y: cy + Math.sin(angle) * r };
    });
    return positions;
  }

  function draw2D() {
    const w = root.clientWidth;
    const h = root.clientHeight;
    const pos = get2DPositions(w, h);

    // Clear
    while (svg2d.firstChild) svg2d.removeChild(svg2d.firstChild);

    // Defs: glow filters
    const defs = document.createElementNS(NS, "defs");

    // Central glow
    const fCentral = document.createElementNS(NS, "filter");
    fCentral.setAttribute("id", "glow-central");
    fCentral.setAttribute("x", "-80%"); fCentral.setAttribute("y", "-80%");
    fCentral.setAttribute("width", "260%"); fCentral.setAttribute("height", "260%");
    const feC = document.createElementNS(NS, "feGaussianBlur");
    feC.setAttribute("stdDeviation", "14"); feC.setAttribute("result", "blur");
    const feM1 = document.createElementNS(NS, "feMerge");
    [document.createElementNS(NS, "feMergeNode"), document.createElementNS(NS, "feMergeNode")].forEach((n,i) => {
      if (i === 1) n.setAttribute("in", "SourceGraphic");
      feM1.appendChild(n);
    });
    fCentral.appendChild(feC); fCentral.appendChild(feM1);
    defs.appendChild(fCentral);

    // Node glow
    const fNode = document.createElementNS(NS, "filter");
    fNode.setAttribute("id", "glow-node");
    fNode.setAttribute("x", "-80%"); fNode.setAttribute("y", "-80%");
    fNode.setAttribute("width", "260%"); fNode.setAttribute("height", "260%");
    const feN = document.createElementNS(NS, "feGaussianBlur");
    feN.setAttribute("stdDeviation", "8"); feN.setAttribute("result", "blur");
    const feM2 = document.createElementNS(NS, "feMerge");
    [document.createElementNS(NS, "feMergeNode"), document.createElementNS(NS, "feMergeNode")].forEach((n,i) => {
      if (i === 1) n.setAttribute("in", "SourceGraphic");
      feM2.appendChild(n);
    });
    fNode.appendChild(feN); fNode.appendChild(feM2);
    defs.appendChild(fNode);

    // Nebula cloud filter for 2D halos
    const fNebula = document.createElementNS(NS, "filter");
    fNebula.setAttribute("id", "nebula-cloud");
    fNebula.setAttribute("x", "-50%"); fNebula.setAttribute("y", "-50%");
    fNebula.setAttribute("width", "200%"); fNebula.setAttribute("height", "200%");
    const feTurb = document.createElementNS(NS, "feTurbulence");
    feTurb.setAttribute("type", "fractalNoise");
    feTurb.setAttribute("baseFrequency", "0.04");
    feTurb.setAttribute("numOctaves", "4");
    feTurb.setAttribute("seed", "2");
    feTurb.setAttribute("result", "noise");
    fNebula.appendChild(feTurb);
    const feDisp = document.createElementNS(NS, "feDisplacementMap");
    feDisp.setAttribute("in", "SourceGraphic");
    feDisp.setAttribute("in2", "noise");
    feDisp.setAttribute("scale", "18");
    feDisp.setAttribute("xChannelSelector", "R");
    feDisp.setAttribute("yChannelSelector", "G");
    feDisp.setAttribute("result", "displaced");
    fNebula.appendChild(feDisp);
    const feBlurNeb = document.createElementNS(NS, "feGaussianBlur");
    feBlurNeb.setAttribute("in", "displaced");
    feBlurNeb.setAttribute("stdDeviation", "4");
    fNebula.appendChild(feBlurNeb);
    defs.appendChild(fNebula);

    svg2d.appendChild(defs);

    // Bridge gradient blobs along edges (drawn first, behind everything)
    const emissiveMap2D = new Map<string, number>();
    for (const n of simNodes) emissiveMap2D.set(n.id, n.emissive);

    for (let li = 0; li < links.length; li++) {
      const link = links[li];
      const srcId = typeof link.source === "string" ? link.source : (link.source as any).id;
      const tgtId = typeof link.target === "string" ? link.target : (link.target as any).id;
      const s = pos[srcId], t = pos[tgtId];
      if (!s || !t) continue;
      const srcHex = "#" + (emissiveMap2D.get(srcId) ?? 0xa855f7).toString(16).padStart(6, "0");
      const tgtHex = "#" + (emissiveMap2D.get(tgtId) ?? 0xa855f7).toString(16).padStart(6, "0");

      const gradId = `bridge-grad-${li}`;
      const grad = document.createElementNS(NS, "linearGradient");
      grad.setAttribute("id", gradId);
      grad.setAttribute("x1", String(s.x)); grad.setAttribute("y1", String(s.y));
      grad.setAttribute("x2", String(t.x)); grad.setAttribute("y2", String(t.y));
      grad.setAttribute("gradientUnits", "userSpaceOnUse");
      const stop1 = document.createElementNS(NS, "stop");
      stop1.setAttribute("offset", "0%"); stop1.setAttribute("stop-color", srcHex);
      const stop2 = document.createElementNS(NS, "stop");
      stop2.setAttribute("offset", "100%"); stop2.setAttribute("stop-color", tgtHex);
      grad.appendChild(stop1); grad.appendChild(stop2);
      defs.appendChild(grad);

      const bridgeLine = document.createElementNS(NS, "line");
      bridgeLine.setAttribute("x1", String(s.x)); bridgeLine.setAttribute("y1", String(s.y));
      bridgeLine.setAttribute("x2", String(t.x)); bridgeLine.setAttribute("y2", String(t.y));
      bridgeLine.setAttribute("stroke", `url(#${gradId})`);
      bridgeLine.setAttribute("stroke-width", "28");
      bridgeLine.setAttribute("stroke-linecap", "round");
      bridgeLine.setAttribute("opacity", "0.08");
      bridgeLine.setAttribute("filter", "url(#nebula-cloud)");
      svg2d.appendChild(bridgeLine);
    }

    // Draw edges (faint, behind nodes)
    for (const link of links) {
      const srcId = typeof link.source === "string" ? link.source : (link.source as any).id;
      const tgtId = typeof link.target === "string" ? link.target : (link.target as any).id;
      const s = pos[srcId], t = pos[tgtId];
      if (!s || !t) continue;
      const line = document.createElementNS(NS, "line");
      line.setAttribute("x1", String(s.x)); line.setAttribute("y1", String(s.y));
      line.setAttribute("x2", String(t.x)); line.setAttribute("y2", String(t.y));
      line.setAttribute("stroke", "rgba(168,85,247,0.1)");
      line.setAttribute("stroke-width", "1.5");
      svg2d.appendChild(line);
    }

    // Draw nodes
    for (const n of simNodes) {
      const p = pos[n.id];
      if (!p) continue;
      const isCentral = n.id === "wiki";
      const r = isCentral ? 26 : 18;
      const hexColor = "#" + n.color.toString(16).padStart(6, "0");
      const hexEmit  = "#" + n.emissive.toString(16).padStart(6, "0");

      const g = document.createElementNS(NS, "g");
      g.setAttribute("transform", `translate(${p.x},${p.y})`);
      if (!isCentral) {
        g.style.cursor = "pointer";
        g.setAttribute("data-route", (n as any).route ?? "");
        g.setAttribute("data-label", n.label);
        g.setAttribute("data-desc",  (n as any).desc ?? "");
        g.setAttribute("data-guides", String((n as any).guides ?? 0));
      }

      // Nebula cloud halo layers
      const haloOuter = document.createElementNS(NS, "circle");
      haloOuter.setAttribute("r", String(r * 3));
      haloOuter.setAttribute("fill", hexEmit);
      haloOuter.setAttribute("opacity", isCentral ? "0.1" : "0.07");
      haloOuter.setAttribute("filter", "url(#nebula-cloud)");
      g.appendChild(haloOuter);

      const haloMid = document.createElementNS(NS, "circle");
      haloMid.setAttribute("r", String(r * 2));
      haloMid.setAttribute("fill", hexEmit);
      haloMid.setAttribute("opacity", isCentral ? "0.16" : "0.12");
      haloMid.setAttribute("filter", "url(#nebula-cloud)");
      g.appendChild(haloMid);

      const haloInner = document.createElementNS(NS, "circle");
      haloInner.setAttribute("r", String(r * 1.3));
      haloInner.setAttribute("fill", hexEmit);
      haloInner.setAttribute("opacity", isCentral ? "0.24" : "0.16");
      g.appendChild(haloInner);

      // Main sphere
      const circle = document.createElementNS(NS, "circle");
      circle.setAttribute("r", String(r));
      circle.setAttribute("fill", hexColor);
      circle.setAttribute("filter", `url(#${isCentral ? "glow-central" : "glow-node"})`);
      g.appendChild(circle);

      // Invisible hit-area for easier clicking/tapping
      if (!isCentral) {
        const hit = document.createElementNS(NS, "circle");
        hit.setAttribute("r", String(r + 20));
        hit.setAttribute("fill", "transparent");
        g.appendChild(hit);
      }

      // Label (non-central)
      if (!isCentral) {
        const label = document.createElementNS(NS, "text");
        label.setAttribute("y", String(r + 22));
        label.setAttribute("text-anchor", "middle");
        label.setAttribute("font-family", "Georgia, serif");
        label.setAttribute("font-style", "italic");
        label.setAttribute("font-size", "14");
        label.setAttribute("fill", "rgba(255,255,255,0.92)");
        label.setAttribute("pointer-events", "none");
        label.textContent = n.label;
        g.appendChild(label);
      }

      svg2d.appendChild(g);

      // Click to navigate
      if (!isCentral) {
        g.addEventListener("click", () => {
          const route = g.getAttribute("data-route");
          if (route) window.location.href = route;
        });

        // Hover tooltip reuse
        g.addEventListener("mouseenter", (e: MouseEvent) => {
          tipName.textContent  = g.getAttribute("data-label") ?? "";
          tipDesc.textContent  = g.getAttribute("data-desc") ?? "";
          const cnt = g.getAttribute("data-guides") ?? "0";
          tipCount.textContent = `${String(cnt).padStart(2,"0")} GUIDES`;
          tip.style.left = `${e.clientX + 16}px`;
          tip.style.top  = `${e.clientY - 14}px`;
          tip.classList.add("visible");
        });
        g.addEventListener("mousemove", (e: MouseEvent) => {
          tip.style.left = `${e.clientX + 16}px`;
          tip.style.top  = `${e.clientY - 14}px`;
        });
        g.addEventListener("mouseleave", () => tip.classList.remove("visible"));
      }
    }
  }

  const eyebrowWrap  = document.querySelector(".hero-eyebrow-wrap")  as HTMLElement;
  const headlineWrap = document.querySelector(".hero-headline-wrap") as HTMLElement;
  const searchWrap   = document.querySelector(".hero-search-wrap")   as HTMLElement;

  function enable2D() {
    is2D = true;
    canvas.style.display    = "none";
    labelEl.style.display   = "none";
    hint3d.style.display    = "none";
    hint2d.style.display    = "";
    graph2dEl.style.display = "";
    // Ensure graph-focused class (which hides headline/eyebrow) is cleared
    root.classList.remove("graph-focused");
    toggleLabel.textContent = "3D";
    toggleBtn.setAttribute("aria-label", "Switch to 3D view");
    toggleBtn.setAttribute("title", "Switch to 3D view");
    draw2D();
  }

  function enable3D() {
    is2D = false;
    canvas.style.display    = "";
    labelEl.style.display   = "";
    hint3d.style.display    = "";
    hint2d.style.display    = "none";
    graph2dEl.style.display = "none";
    tip.classList.remove("visible");
    toggleLabel.textContent = "2D";
    toggleBtn.setAttribute("aria-label", "Switch to 2D view");
    toggleBtn.setAttribute("title", "Switch to 2D view");
  }

  toggleBtn.addEventListener("click", () => {
    if (is2D) enable3D(); else enable2D();
  });

  // Auto-fallback: if WebGL context is lost or unavailable, switch to 2D
  canvas.addEventListener("webglcontextlost", (e) => {
    e.preventDefault();
    enable2D();
  });
</script>
