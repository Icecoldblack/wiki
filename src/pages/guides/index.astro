---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import CategoryCard from "../../components/CategoryCard.astro";
---

<Layout title="Guides">
  <PageHeader
    eyebrow="Guides"
    headline="everything you need<br>to break in."
    subline="Signed, dated, and written by people who've been through it."
  />

  <section class="guide-journey">
    <!-- Featured entry point -->
    <div class="journey__featured">
      <CategoryCard
        title="zero to hero"
        href="/guides/zero-to-hero"
        description="Start here. CS fundamentals, math intuition, and the first principles that make everything else click."
        count={8}
        variant="featured"
        eyebrow="Start here"
      />
    </div>

    <!-- Middle tier — two columns on desktop -->
    <div class="journey__mid">
      <CategoryCard
        title="technical"
        href="/guides/technical"
        description="Leetcode, system design, and take-homes — how to actually prep for coding interviews."
        count={9}
      />
      <CategoryCard
        title="career"
        href="/guides/career"
        description="Resumes, timelines, offer negotiation, and how to navigate the hiring process."
        count={12}
      />
    </div>

    <div class="journey__mid">
      <CategoryCard
        title="networking"
        href="/guides/networking"
        description="Cold outreach, LinkedIn, warm intros, and building real relationships that lead somewhere."
        count={6}
      />
      <CategoryCard
        title="misc"
        href="/guides/misc"
        description="Tools, productivity, and everything else worth knowing."
        count={4}
      />
    </div>
  </section>
</Layout>

<style>
  .guide-journey {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .journey__mid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .journey__mid {
      grid-template-columns: 1fr;
    }
  }
</style>
