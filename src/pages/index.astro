---
import Layout from "../layouts/Layout.astro";
import { NAV_LINKS } from "../consts";
---

<Layout title="Home">
  <div class="text-center py-16">
    <h1 class="text-4xl font-bold text-white mb-4">Welcome to ProgSU Wiki</h1>
    <p class="text-lg text-gray-400 max-w-xl mx-auto mb-10">
      Your go-to knowledge base for guides, courses, and resources — built for CS students at GSU.
    </p>
    <div class="flex gap-4 justify-center">
      <a
        href="/guides"
        class="bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors no-underline"
      >
        Browse Guides
      </a>
      <a
        href="/courses"
        class="border border-gray-600 hover:border-gray-400 text-gray-300 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors no-underline"
      >
        View Courses
      </a>
    </div>
  </div>
</Layout>
