---
import Layout from "../../layouts/Layout.astro";

const categories = [
  { title: "Foundations", href: "/guides/foundations", description: "Core CS concepts and fundamentals every student should know." },
  { title: "Career", href: "/guides/career", description: "Resume tips, internship hunting, and breaking into tech." },
  { title: "Technical", href: "/guides/technical", description: "Coding interviews, DSA practice, and technical prep." },
  { title: "Networking", href: "/guides/networking", description: "Building connections, LinkedIn, and community involvement." },
  { title: "Misc", href: "/guides/misc", description: "Everything else — tools, productivity, and student life." },
];
---

<Layout title="Guides">
  <h1 class="text-3xl font-bold text-white mb-2">Guides</h1>
  <p class="text-gray-400 mb-10">Browse all guide categories below.</p>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      categories.map((cat) => (
        <a
          href={cat.href}
          class="block p-6 rounded-xl border border-gray-800 hover:border-indigo-500 bg-gray-900 hover:bg-gray-800 transition-colors no-underline"
        >
          <h2 class="text-lg font-semibold text-white mb-1">{cat.title}</h2>
          <p class="text-sm text-gray-400">{cat.description}</p>
        </a>
      ))
    }
  </div>
</Layout>
