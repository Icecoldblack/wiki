    .hero__code { font-size: var(--text-xl); }
    .hero__title { font-size: var(--text-3xl); }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .hero__actions {
      flex-direction: column;
    }
    .hero__cta {
      text-align: center;
    }
  }
</style>

<script>

  // ── Section filters ──
  const timeChips = document.querySelectorAll<HTMLButtonElement>('[data-filter-time]');
  const openOnlyCheck = document.getElementById('sec-open-only') as HTMLInputElement | null;
  const sectionRows = document.querySelectorAll<HTMLElement>('[data-section-row]');
  const secEmpty = document.getElementById('sec-empty');

  function applySectionFilters() {
    const activeTimes = new Set<string>();
    timeChips.forEach(c => { if (c.classList.contains('active')) activeTimes.add(c.dataset.filterTime!); });
    const filterByTime = activeTimes.size > 0;
    const onlyOpen = openOnlyCheck?.checked ?? false;

    let visible = 0;
    sectionRows.forEach(row => {
      let show = true;
      if (filterByTime && !activeTimes.has(row.dataset.time ?? '')) show = false;
      if (onlyOpen && Number(row.dataset.seats ?? '0') <= 0) show = false;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (secEmpty) secEmpty.style.display = visible === 0 ? '' : 'none';
  }

  timeChips.forEach(chip => {
    chip.addEventListener('click', () => {
      chip.classList.toggle('active');
      applySectionFilters();
    });
  });
  openOnlyCheck?.addEventListener('change', applySectionFilters);
</script>
